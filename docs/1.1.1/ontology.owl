    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->





    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>



    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>



    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>



    <!-- http://purl.org/dc/terms/issued -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>



    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>



    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>



    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>



    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>



    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>



    <!-- http://www.w3.org/2003/06/sw-vocab-status/ns#term_status -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/06/sw-vocab-status/ns#term_status"/>



    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>



    <!-- http://www.w3.org/2004/02/skos/core#scopeNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#scopeNote"/>



    <!-- http://www.w3.org/2006/vcard/ns#fn -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2006/vcard/ns#fn"/>



    <!-- https://schema.org/domainIncludes -->


    <owl:AnnotationProperty rdf:about="https://schema.org/domainIncludes"/>



    <!-- https://schema.org/name -->


    <owl:AnnotationProperty rdf:about="https://schema.org/name"/>



    <!-- https://schema.org/rangeIncludes -->


    <owl:AnnotationProperty rdf:about="https://schema.org/rangeIncludes"/>



    <!-- https://w3id.org/ficr#according_to -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/ficr#according_to"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->





    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->





    <!-- https://w3id.org/ficr#aboutElement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#aboutElement">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">Links a boundary condition record to the physical object whose fire-related boundary or performance condition it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">aboutElement</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#appliesToElementType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#appliesToElementType">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatoryRequirement"/>
        <rdfs:comment xml:lang="en">Specifies the class of physical element this requirement applies to, e.g. ficr:Wall or ficr:Floor.</rdfs:comment>
        <rdfs:label xml:lang="en">appliesToElementType</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#appliesToPurposeGroup -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#appliesToPurposeGroup">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatoryRequirement"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
        <rdfs:comment xml:lang="en">Specifies the building purpose group for which this requirement is applicable.</rdfs:comment>
        <rdfs:label xml:lang="en">appliesToPurposeGroup</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#appliesToRiskUnit -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#appliesToRiskUnit">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#RiskUnit"/>
        <rdfs:comment xml:lang="en">Links a boundary condition record to the risk unit whose fire risk interpretation it informs.</rdfs:comment>
        <rdfs:label xml:lang="en">appliesToRiskUnit</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#assessesElement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#assessesElement">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">Links an assessment to the physical element(s) it evaluates. For compliance assessments, this is the wall, door, or floor being checked. For risk assessments, this covers elements involved in fire spread modelling.</rdfs:comment>
        <rdfs:label xml:lang="en">assessesElement</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#assessesZone -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#assessesZone">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">Links an assessment to the zone(s) or space(s) it covers. For risk assessments, this is the space whose fire scenario is being evaluated. For compliance assessments, this is the space containing the assessed elements.</rdfs:comment>
        <rdfs:label xml:lang="en">assessesZone</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#checksRequirement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#checksRequirement">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#ComplianceFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#RegulatoryRequirement"/>
        <rdfs:comment xml:lang="en">Links a compliance finding to the regulatory requirement being checked.</rdfs:comment>
        <rdfs:label xml:lang="en">checksRequirement</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#concernsElement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#concernsElement">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">Links an assessment finding to the physical object it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">concernsElement</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#concernsRiskUnit -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#concernsRiskUnit">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#RiskUnit"/>
        <rdfs:comment xml:lang="en">Links an assessment finding to the risk unit it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">concernsRiskUnit</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#concernsSystem -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#concernsSystem">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">Links an assessment finding to the building system it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">concernsSystem</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#concernsZone -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#concernsZone">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">Links an assessment finding to the spatial zone or space it concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">concernsZone</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#containsSystem -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#containsSystem">
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isSystemContainedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">Relates a spatial zone to a building system located in, passing through, or spatially associated with that zone. This property is used where a system-level entity should not be treated as a BOT element.</rdfs:comment>
        <rdfs:label xml:lang="en">containsSystem</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#coversSpatialZone -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#coversSpatialZone">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RiskUnit"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">Links a risk unit to the spatial zone whose fire exposure it aggregates.</rdfs:comment>
        <rdfs:label xml:lang="en">coversSpatialZone</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#dependsOnBoundaryCondition -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#dependsOnBoundaryCondition">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#FireRiskScenario"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:comment xml:lang="en">Links a fire risk scenario to boundary condition records or assumptions that influence the scenario interpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">dependsOnBoundaryCondition</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#derivedFromRegulatorySource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#derivedFromRegulatorySource">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatoryRequirement"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:comment xml:lang="en">Links a regulatory requirement individual to the regulatory, standard, or guidance source from which it was derived.</rdfs:comment>
        <rdfs:label xml:lang="en">derivedFromRegulatorySource</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#derivedFromScenario -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#derivedFromScenario">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RiskFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#FireRiskScenario"/>
        <rdfs:comment xml:lang="en">Links a risk finding to the fire risk scenario from which it was derived, enabling finding-level traceability when one risk analysis evaluates multiple scenarios.</rdfs:comment>
        <rdfs:label xml:lang="en">derivedFromScenario</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasApplicabilityState -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasApplicabilityState">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#ApplicabilityState"/>
        <rdfs:comment xml:lang="en">Records whether an assessment finding or checklist item is applicable, not applicable, or not assessed in the current assessment scope.</rdfs:comment>
        <rdfs:label xml:lang="en">hasApplicabilityState</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasAssessmentBasis -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasAssessmentBasis">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#AssessmentBasis"/>
        <rdfs:comment xml:lang="en">Links an assessment activity or assessment result to the evidence bundle that supports it.</rdfs:comment>
        <rdfs:label xml:lang="en">hasAssessmentBasis</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasBoundaryPerformanceAspect -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasBoundaryPerformanceAspect">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#BoundaryPerformanceAspect"/>
        <rdfs:comment xml:lang="en">Identifies the boundary-related performance aspect assessed by a boundary condition record.</rdfs:comment>
        <rdfs:label xml:lang="en">hasBoundaryPerformanceAspect</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasClassification -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasClassification">
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isClassificationOf"/>
        <rdfs:comment xml:lang="en">General property relating an entity to its classification.</rdfs:comment>
        <rdfs:label xml:lang="en">hasClassification</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasComplianceResult -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasComplianceResult">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#ComplianceFinding"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#ComplianceResult"/>
        <rdfs:comment xml:lang="en">Links a compliance finding to its compliance result.</rdfs:comment>
        <rdfs:label xml:lang="en">hasComplianceResult</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasComponent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasComponent">
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isComponentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">Expressing the compositional relationship of components</rdfs:comment>
        <rdfs:label xml:lang="en">hasComponent</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasConditionState -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasConditionState">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#ConditionState"/>
        <rdfs:comment xml:lang="en">Links a boundary condition record to its assessed condition state, such as effective, compromised, or unknown.</rdfs:comment>
        <rdfs:label xml:lang="en">hasConditionState</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasConnectionWith -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasConnectionWith">
        <rdfs:comment xml:lang="en">indicates that the two individuals have a passageway.</rdfs:comment>
        <rdfs:label xml:lang="en">hasConnectionWith</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasEvidenceStatus -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasEvidenceStatus">
        <rdfs:range rdf:resource="https://w3id.org/ficr#EvidenceStatus"/>
        <rdfs:comment xml:lang="en">Links an assessment finding, boundary condition record, or other assessment-related record to a controlled evidence status. The domain is intentionally left open to avoid forcing all evidence-qualified records into the AssessmentFinding hierarchy.</rdfs:comment>
        <rdfs:label xml:lang="en">hasEvidenceStatus</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasFireSafetyRole -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasFireSafetyRole">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasUsageType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isFireSafetyRoleOf"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">General property linking an entity to a fire safety role. More specific subproperties are used for physical objects, zones, and systems.</rdfs:comment>
        <rdfs:label xml:lang="en">hasFireSafetyRole</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasImpairmentState -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasImpairmentState">
        <rdfs:range rdf:resource="https://w3id.org/ficr#ImpairmentState"/>
        <rdfs:comment xml:lang="en">Links an asset, system, provision, or relevant physical object to its operational impairment state. The domain is intentionally left open because impairment may apply to fire-protection provisions, general equipment, building systems, or other inspected assets.</rdfs:comment>
        <rdfs:label xml:lang="en">hasImpairmentState</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasInstallationStatus -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasInstallationStatus">
        <rdfs:range rdf:resource="https://w3id.org/ficr#InstallationStatus"/>
        <rdfs:comment xml:lang="en">Links an asset, system, provision, or relevant physical object to its installation status. The domain is intentionally left open because installation status may apply to fire-protection provisions, general equipment, and building systems.</rdfs:comment>
        <rdfs:label xml:lang="en">hasInstallationStatus</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasOriginSpace -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasOriginSpace">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#FireRiskScenario"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">Links a fire risk scenario to the zone where the fire is modelled to originate.</rdfs:comment>
        <rdfs:label xml:lang="en">hasOriginSpace</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasFireSafetyRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isPhysicalObjectFireSafetyRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">Assigns a fire safety role to a physical object, such as a wall, doorset, stair, damper, equipment item, or other object relevant to fire assessment.</rdfs:comment>
        <rdfs:label xml:lang="en">hasPhysicalObjectFireSafetyRole</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasPurposeGroup -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasPurposeGroup">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasClassification"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isPurposeGroupOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
        <rdfs:comment xml:lang="en">Relates a building to its functional purpose group classification according to ADB Table 0.1</rdfs:comment>
        <rdfs:label xml:lang="en">hasPurposeGroup</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasScenario -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasScenario">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RiskAnalysis"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#FireRiskScenario"/>
        <rdfs:comment xml:lang="en">Links a risk analysis to the fire risk scenario or scenarios it evaluates. Each scenario represents a hypothetical fire origin and relevant spread or exposure context used for risk-informed interpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">hasScenario</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasScenarioRiskUnit -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasScenarioRiskUnit">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#FireRiskScenario"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#RiskUnit"/>
        <rdfs:comment xml:lang="en">Links a fire risk scenario to the risk unit whose fire risk is being interpreted.</rdfs:comment>
        <rdfs:label xml:lang="en">hasScenarioRiskUnit</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasSpaceUsage -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasSpaceUsage">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasUsageType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isSpaceUsageOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <rdfs:comment xml:lang="en">Assigns an everyday or operational space-use classification to a spatial zone or space, such as kitchen, corridor, lobby, bathroom, habitable room, or place of special hazard.</rdfs:comment>
        <rdfs:label xml:lang="en">hasSpaceUsage</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasSystemFireSafetyRole -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasSystemFireSafetyRole">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasFireSafetyRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isSystemFireSafetyRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">Assigns a fire safety role to a building system, such as active protection, protected supply, evacuation support, or firefighting support.</rdfs:comment>
        <rdfs:label xml:lang="en">hasSystemFireSafetyRole</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasUsageType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasUsageType">
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isUsageTypeOf"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#UsageType"/>
        <rdfs:comment xml:lang="en">Top-level property linking an entity to a usage type classification. Sub-properties specialise domain and range.</rdfs:comment>
        <rdfs:label xml:lang="en">hasUsageType</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasUtilizationPurpose -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasUtilizationPurpose">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasUsageType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isUtilizationPurposeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
        <rdfs:comment xml:lang="en">Assigns a building planning utilization purpose (e.g. Hotel, Office) to a zone or building.</rdfs:comment>
        <rdfs:label xml:lang="en">hasUtilizationPurpose</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#hasZoneFireSafetyRole -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#hasZoneFireSafetyRole">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#hasFireSafetyRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#isZoneFireSafetyRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">Assigns a fire safety role to a spatial zone, enabling protected-space and route-related classifications.</rdfs:comment>
        <rdfs:label xml:lang="en">hasZoneFireSafetyRole</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isClassificationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isClassificationOf">
        <rdfs:comment xml:lang="en">Inverse of hasClassification.</rdfs:comment>
        <rdfs:label xml:lang="en">isClassificationOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isComponentOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isComponentOf">
        <rdfs:comment xml:lang="en">Links an individual equipment item to the building system it belongs to. Inverse direction of hasComponent at the instance level.</rdfs:comment>
        <rdfs:label xml:lang="en">isComponentOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isExposedTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isExposedTo">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RiskUnit"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#RiskUnit"/>
        <rdfs:comment xml:lang="en">Indicates potential fire spread exposure between risk units.</rdfs:comment>
        <rdfs:label xml:lang="en">isExposedTo</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isFireSafetyRoleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isFireSafetyRoleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isUsageTypeOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasFireSafetyRole.</rdfs:comment>
        <rdfs:label xml:lang="en">isFireSafetyRoleOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isLocatedIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isLocatedIn">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">describe the location and/or surroundings of a place.</rdfs:comment>
        <rdfs:label xml:lang="en">isLocatedIn</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isPhysicalObjectFireSafetyRoleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isPhysicalObjectFireSafetyRoleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isFireSafetyRoleOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasPhysicalObjectFireSafetyRole</rdfs:comment>
        <rdfs:label xml:lang="en">isPhysicalObjectFireSafetyRoleOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isPurposeGroupOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isPurposeGroupOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isClassificationOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasPurposeGroup.</rdfs:comment>
        <rdfs:label xml:lang="en">isPurposeGroupOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isSpaceUsageOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isSpaceUsageOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isUsageTypeOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasSpaceUsage.</rdfs:comment>
        <rdfs:label xml:lang="en">isSpaceUsageOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isStoreyAbove -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isStoreyAbove">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Storey"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Storey"/>
        <rdfs:comment xml:lang="en">Indicates that the subject storey is directly above the object storey.</rdfs:comment>
        <rdfs:label xml:lang="en">isStoreyAbove</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isStoreyBelow -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isStoreyBelow">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Storey"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Storey"/>
        <rdfs:comment xml:lang="en">Indicates that the subject storey is directly below the object storey.</rdfs:comment>
        <rdfs:label xml:lang="en">isStoreyBelow</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isSystemContainedIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isSystemContainedIn">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:range rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">inverseOf containsSystem</rdfs:comment>
        <rdfs:label xml:lang="en">isSystemContainedIn</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isSystemFireSafetyRoleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isSystemFireSafetyRoleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isFireSafetyRoleOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasFireSafetyRole, linking a fire safety role to the system or element that bears it.</rdfs:comment>
        <rdfs:label xml:lang="en">isSystemFireSafetyRoleOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isUsageTypeOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isUsageTypeOf">
        <rdfs:comment xml:lang="en">Inverse of hasUsageType.</rdfs:comment>
        <rdfs:label xml:lang="en">isUsageTypeOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isUtilizationPurposeOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isUtilizationPurposeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isUsageTypeOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasUtilizationPurpose.</rdfs:comment>
        <rdfs:label xml:lang="en">isUtilizationPurposeOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#isZoneFireSafetyRoleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#isZoneFireSafetyRoleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ficr#isFireSafetyRoleOf"/>
        <rdfs:comment xml:lang="en">Inverse of hasZoneFireSafetyRole.</rdfs:comment>
        <rdfs:label xml:lang="en">isZoneFireSafetyRoleOf</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#producesAssessment -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#producesAssessment">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:comment xml:lang="en">Links a task to the assessment record produced by executing that task.</rdfs:comment>
        <rdfs:label xml:lang="en">producesAssessment</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#producesEvidence -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#producesEvidence">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">Links a task to evidence items it generates.</rdfs:comment>
        <rdfs:label xml:lang="en">producesEvidence</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#producesFinding -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#producesFinding">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:comment xml:lang="en">Links an assessment to the findings it produces.</rdfs:comment>
        <rdfs:label xml:lang="en">producesFinding</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#reliesOnBoundaryCondition -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#reliesOnBoundaryCondition">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:comment xml:lang="en">Links an assessment to a boundary condition record that it relies on or interprets. This allows compliance checking and risk analysis to expose whether their conclusions depend on effective, compromised, unknown, or weakly evidenced boundary conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">reliesOnBoundaryCondition</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#supportedByEvidence -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#supportedByEvidence">
        <rdfs:range rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">Links an assessment finding, boundary condition record, or other assessment-related record to evidence items that support, justify, or document it. The domain is intentionally left open because evidence support is used both for produced findings and for assessment dependencies such as boundary condition records.</rdfs:comment>
        <rdfs:label xml:lang="en">supportedByEvidence</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#triggeredBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#triggeredBy">
        <owl:inverseOf rdf:resource="https://w3id.org/ficr#triggersTask"/>
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#Event"/>
        <rdfs:comment xml:lang="en">A task is created because an event (e.g., risk detected) occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">triggeredBy</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#triggersTask -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#triggersTask">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Event"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:comment xml:lang="en">Links a trigger event to the task(s) created because of it.</rdfs:comment>
        <rdfs:label xml:lang="en">triggersTask</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#usesComplianceFinding -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#usesComplianceFinding">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RiskAnalysis"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#ComplianceFinding"/>
        <rdfs:comment xml:lang="en">Links a risk analysis to compliance findings used as inputs for risk interpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">usesComplianceFinding</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/ficr#usesEvidence -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ficr#usesEvidence">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:range rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">Links a task to evidence items it consumes as inputs.</rdfs:comment>
        <rdfs:label xml:lang="en">usesEvidence</rdfs:label>
    </owl:ObjectProperty>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->





    <!-- https://w3id.org/ficr#documentTitle -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#documentTitle">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentBasis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A human-readable title used to display the document in user interfaces.</rdfs:comment>
        <rdfs:label xml:lang="en">documentTitle</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#documentURI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#documentURI">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentBasis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">A resolvable URI or file path pointing to the document location for human access.</rdfs:comment>
        <rdfs:label xml:lang="en">documentURI</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasActualREI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasActualREI">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The actual measured fire resistance period (R=load-bearing, E=integrity, I=insulation) in minutes.</rdfs:comment>
        <rdfs:label xml:lang="en">hasActualREI</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasArea -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasArea">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The floor area of a space in square metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasArea</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasBuildingHeight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasBuildingHeight">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Height of a building is measured as shown in Appendix D, Diagram D4.</rdfs:comment>
        <rdfs:label xml:lang="en">hasBuildingHeight</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasClauseReference -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasClauseReference">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatoryRequirement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Records the clause, table, paragraph, section, or provision reference from which a regulatory requirement was derived.</rdfs:comment>
        <rdfs:label xml:lang="en">hasClauseReference</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasCombinedGrossFloorArea -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasCombinedGrossFloorArea">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Total gross floor area of all storeys in a building, in square metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasCombinedGrossFloorArea</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasCoverageType -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasCoverageType">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Alarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The spatial coverage mode of the detector, e.g. PointDetector, BeamDetector, AspiratingDetector.</rdfs:comment>
        <rdfs:label xml:lang="en">hasCoverageType</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasDetectionType -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasDetectionType">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Alarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The detection principle of the alarm device, e.g. OpticalSmoke, Ionisation, Heat, MultiSensor, CarbonMonoxide.</rdfs:comment>
        <rdfs:label xml:lang="en">hasDetectionType</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasDirectDistance -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasDirectDistance">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The shortest distance from any point within the floor area to the nearest storey exit, measured within the external enclosures of the building, and ignoring walls, partitions and fittings other than the enclosing walls and partitions to protected stairways.</rdfs:comment>
        <rdfs:label xml:lang="en">hasDirectDistance</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasElevation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasElevation">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The vertical height of a storey floor level above a reference datum, in metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasElevation</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasExtinguisherAgent -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasExtinguisherAgent">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#FireExtinguisher"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The extinguishing agent type, e.g. DryPowder, CO2, WaterMist, WetChemical, Foam.</rdfs:comment>
        <rdfs:label xml:lang="en">hasExtinguisherAgent</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasFindingStatement -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasFindingStatement">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A human-readable statement of what the finding records. Used for expected-vs-actual validation tables and reporting.</rdfs:comment>
        <rdfs:label xml:lang="en">hasFindingStatement</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasFireClassRating -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasFireClassRating">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#FireExtinguisher"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The fire class rating per BS EN 2, e.g. A, B, AB, ABC, AF.</rdfs:comment>
        <rdfs:label xml:lang="en">hasFireClassRating</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasFixedAssetValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasFixedAssetValue">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">This refers to the total asset value of the space.</rdfs:comment>
        <rdfs:label xml:lang="en">hasFixedAssetValue</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasID -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasID">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A unique identifier string for the entity.</rdfs:comment>
        <rdfs:label xml:lang="en">hasID</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasJurisdiction -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasJurisdiction">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Specifies the jurisdiction in which a regulatory source, requirement, or assessment context applies.</rdfs:comment>
        <rdfs:label xml:lang="en">hasJurisdiction</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasLength -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasLength">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The length dimension of a building element, in metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasLength</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasNumberOfStoreys -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasNumberOfStoreys">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of storeys excluding basements</rdfs:comment>
        <rdfs:label xml:lang="en">hasNumberOfStoreys</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasRequiredREI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasRequiredREI">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatoryRequirement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The minimum REI value mandated by regulation for a given element type and purpose group, in minutes.</rdfs:comment>
        <rdfs:label xml:lang="en">hasRequiredREI</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasScenarioDescription -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasScenarioDescription">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#FireRiskScenario"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provides a narrative description of the fire risk scenario, including where the fire is assumed to originate, how it may spread, and why it is expected to stop or be limited.</rdfs:comment>
        <rdfs:label xml:lang="en">hasScenarioDescription</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasServiceExpiryDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasServiceExpiryDate">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Equipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date by which the equipment must be serviced or replaced to remain compliant.</rdfs:comment>
        <rdfs:label xml:lang="en">hasServiceExpiryDate</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasSourceEdition -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasSourceEdition">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Records the edition, year, version, or publication date of a regulatory, standards, or guidance source.</rdfs:comment>
        <rdfs:label xml:lang="en">hasSourceEdition</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasSourcePublisher -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasSourcePublisher">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Records the issuing body or publisher of a regulatory, standards, or guidance source.</rdfs:comment>
        <rdfs:label xml:lang="en">hasSourcePublisher</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasStoreyHeight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasStoreyHeight">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The floor-to-floor height of a storey, in metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasStoreyHeight</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasThickness -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasThickness">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The thickness dimension of a building element, in metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasThickness</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasTopStoreyFloorHeight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasTopStoreyFloorHeight">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Height of the floor of the top storey above ground level is measured as shown in Appendix D, Diagram D6.</rdfs:comment>
        <rdfs:label xml:lang="en">hasTopStoreyFloorHeight</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasTopStoreyHeight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasTopStoreyHeight">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The floor-to-ceiling height of the topmost storey, in metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasTopStoreyHeight</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasTravelDistance -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasTravelDistance">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">(unless otherwise specified, e.g. as in the case of flats) The distance that a person would travel from any point within the floor area to the nearest storey exit, determined by the layout of walls, partitions and fittings.</rdfs:comment>
        <rdfs:label xml:lang="en">hasTravelDistance</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasVolume -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasVolume">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The volume of a space, in cubic metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasVolume</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#hasWidth -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#hasWidth">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The width dimension of a building element, in metres.</rdfs:comment>
        <rdfs:label xml:lang="en">hasWidth</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#isAboveGround -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#isAboveGround">
        <rdfs:domain rdf:resource="https://w3id.org/bot#Storey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Determine whether the storey is a basement or above ground.</rdfs:comment>
        <rdfs:label xml:lang="en">isAboveGround</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#isDamaged -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#isDamaged">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean indicating whether the element shows visible damage affecting its fire performance.</rdfs:comment>
        <rdfs:label xml:lang="en">isDamaged</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#isEnclosed -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#isEnclosed">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean indicating whether the element or space is fully enclosed by construction.</rdfs:comment>
        <rdfs:label xml:lang="en">isEnclosed</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#isExternal -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#isExternal">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean indicating whether the element forms part of the external building envelope.</rdfs:comment>
        <rdfs:label xml:lang="en">isExternal</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#isLoadBearing -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#isLoadBearing">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean indicating whether the element carries structural loads.</rdfs:comment>
        <rdfs:label xml:lang="en">isLoadBearing</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#isObscured -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#isObscured">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Refers to the state of being obscured.</rdfs:comment>
        <rdfs:label xml:lang="en">isObscured</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#plannedEndTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#plannedEndTime">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The scheduled end date and time of a task.</rdfs:comment>
        <rdfs:label xml:lang="en">plannedEndTime</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#plannedStartTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#plannedStartTime">
        <rdfs:domain rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The scheduled start date and time of a task.</rdfs:comment>
        <rdfs:label xml:lang="en">plannedStartTime</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/ficr#requiresInspection -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ficr#requiresInspection">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Must be subject to inspection assignments (e.g., fire safety inspections).</rdfs:comment>
        <rdfs:label xml:lang="en">requiresInspection</rdfs:label>
    </owl:DatatypeProperty>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->





    <!-- https://w3id.org/ficr#AccessRoomRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#AccessRoomRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Accommodation -->


    <owl:Class rdf:about="https://w3id.org/ficr#Accommodation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ActiveFireProtectionRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#ActiveFireProtectionRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Alarm -->


    <owl:Class rdf:about="https://w3id.org/ficr#Alarm">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionEquipment"/>
        <rdfs:comment xml:lang="en">An individual fire alarm equipment item or device that provides warning functionality within a fire alarm or detection arrangement. This class represents equipment-level alarm items.</rdfs:comment>
        <rdfs:label xml:lang="en">Alarm</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#AlternativeEscapeRouteRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#AlternativeEscapeRouteRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#AlternativeExitRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#AlternativeExitRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#AnomalyTriggerEvent -->


    <owl:Class rdf:about="https://w3id.org/ficr#AnomalyTriggerEvent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Event"/>
        <rdfs:comment xml:lang="en">A trigger event generated when abnormal conditions are detected by monitoring or analytics, causing tasks to be created for verification, inspection, or risk follow-up.</rdfs:comment>
        <rdfs:label xml:lang="en">AnomalyTriggerEvent</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ApplianceVentilationDuct -->


    <owl:Class rdf:about="https://w3id.org/ficr#ApplianceVentilationDuct">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#HVACSystem"/>
        <rdfs:comment xml:lang="en">A duct to deliver combustion air to a gas appliance.</rdfs:comment>
        <rdfs:label xml:lang="en">ApplianceVentilationDuct</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ApplicabilityState -->


    <owl:Class rdf:about="https://w3id.org/ficr#ApplicabilityState">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentState"/>
        <rdfs:comment xml:lang="en">A controlled state indicating whether a requirement, rule, or assessment condition applies in a given context.</rdfs:comment>
        <rdfs:label xml:lang="en">ApplicabilityState</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Applicable -->


    <owl:Class rdf:about="https://w3id.org/ficr#Applicable">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ApplicabilityState"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NotApplicable"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NotAssessed"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#AssemblyPlace -->


    <owl:Class rdf:about="https://w3id.org/ficr#AssemblyPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Assessment -->


    <owl:Class rdf:about="https://w3id.org/ficr#Assessment">
        <rdfs:comment xml:lang="en">A fire-related assessment record produced through an O&amp;M task. It may represent compliance checking, risk analysis, or inspection assessment and can produce assessment findings.</rdfs:comment>
        <rdfs:label xml:lang="en">Assessment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#AssessmentBasis -->


    <owl:Class rdf:about="https://w3id.org/ficr#AssessmentBasis">
        <rdfs:comment xml:lang="en">A bundle of evidence items used to justify a fire compliance evaluation or risk assessment. It groups observed site evidence, regulatory sources, and supporting external documents for traceability and explanation.</rdfs:comment>
        <rdfs:label xml:lang="en">AssessmentBasis</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#AssessmentFinding -->


    <owl:Class rdf:about="https://w3id.org/ficr#AssessmentFinding">
        <rdfs:comment xml:lang="en">A record produced by an assessment to capture a compliance, risk, or inspection finding concerning an assessed element, system, zone, risk unit, requirement, or scenario. Findings may be linked to evidence, evidence status, and assessment results where applicable.</rdfs:comment>
        <rdfs:label xml:lang="en">AssessmentFinding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#AssessmentState -->


    <owl:Class rdf:about="https://w3id.org/ficr#AssessmentState">
        <rdfs:comment xml:lang="en">An abstract superclass for controlled state or result values used in FiCR assessments, including boundary condition states, operational impairment states, evidence states, applicability states, and compliance results. Subclasses retain their domain-specific meanings and are not merged.</rdfs:comment>
        <rdfs:label xml:lang="en">AssessmentState</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#AtriumSpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#AtriumSpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#BalconySpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#CavitySpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#DuctSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoofSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoomSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">A continuous space that passes through one or more structural floors within a building, not necessarily vertically.
Enclosed lift wells, enclosed escalator wells, building services ducts and stairs are not classified as atria.</rdfs:comment>
        <rdfs:label xml:lang="en">AtriumSpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Auditorium -->


    <owl:Class rdf:about="https://w3id.org/ficr#Auditorium">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Bathroom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Gallery"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#HabitableRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Kitchen"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#AutomaticReleaseMechanism -->


    <owl:Class rdf:about="https://w3id.org/ficr#AutomaticReleaseMechanism">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionEquipment"/>
        <rdfs:comment xml:lang="en">A device that normally holds a door open, but closes it automatically if any one of the following occurs.
• Smoke is detected by an automatic device of a suitable nature and quality in a suitable location.
• A hand-operated switch, fitted in a suitable position, is operated.
• The electricity supply to the device, apparatus or switch fails.
• The fire alarm system, if any, is operated.</rdfs:comment>
        <rdfs:label xml:lang="en">AutomaticReleaseMechanism</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BalconySpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#BalconySpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#CavitySpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#DuctSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoofSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoomSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">A balcony is a platform projecting from the wall of a building, enclosed by a balustrade or railing, and accessed from an upper-level room.</rdfs:comment>
        <rdfs:label xml:lang="en">BalconySpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BasementStorey -->


    <owl:Class rdf:about="https://w3id.org/ficr#BasementStorey">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Storey"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#isAboveGround"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Storey"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#GroundAndAboveStorey"/>
        <rdfs:comment xml:lang="en">A storey with a floor that, at some point, is more than 1200mm below the highest level of ground beside the outside walls. (However, see Appendix B, paragraph B26c, for situations where the storey is considered to be a basement only because of a sloping site.)</rdfs:comment>
        <rdfs:label xml:lang="en">BasementStorey</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Bathroom -->


    <owl:Class rdf:about="https://w3id.org/ficr#Bathroom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Gallery"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#HabitableRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Kitchen"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Beam -->


    <owl:Class rdf:about="https://w3id.org/ficr#Beam">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#StructuralElement"/>
        <rdfs:comment xml:lang="en">A beam is a horizontal structural element that carries loads perpendicular to its length, transferring weight from a roof, floor, or ceiling to vertical supports like columns or walls.</rdfs:comment>
        <rdfs:label xml:lang="en">Beam</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BoardingHouse -->


    <owl:Class rdf:about="https://w3id.org/ficr#BoardingHouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#BoilerRoom -->


    <owl:Class rdf:about="https://w3id.org/ficr#BoilerRoom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EngineRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#FuelStorage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#SwitchGearRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#TransformerRoom"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#BoundaryAssumption -->


    <owl:Class rdf:about="https://w3id.org/ficr#BoundaryAssumption">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BoundaryConditionRecord"/>
        <rdfs:comment xml:lang="en">A boundary condition record used where risk analysis relies on an assumed, incomplete, or provisionally assessed boundary-performance condition. It may later be confirmed, revised, or replaced by inspection evidence.</rdfs:comment>
        <rdfs:label xml:lang="en">BoundaryAssumption</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BoundaryConditionRecord -->


    <owl:Class rdf:about="https://w3id.org/ficr#BoundaryConditionRecord">
        <rdfs:comment xml:lang="en">A record describing the assessed or assumed condition of a fire-related boundary or boundary-performance aspect within a risk unit. It may be used as an assessment dependency and can be linked to condition state, evidence status, supporting evidence, and related physical elements.</rdfs:comment>
        <rdfs:label xml:lang="en">BoundaryConditionRecord</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BoundaryPerformanceAspect -->


    <owl:Class rdf:about="https://w3id.org/ficr#BoundaryPerformanceAspect">
        <rdfs:comment xml:lang="en">A classification of the boundary-related performance aspect considered in fire risk interpretation, such as compartmentation, cavity barrier performance, external fire spread, or structural stability.</rdfs:comment>
        <rdfs:label xml:lang="en">BoundaryPerformanceAspect</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BuildingContent -->


    <owl:Class rdf:about="https://w3id.org/ficr#BuildingContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Element"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">A movable or non-integral physical object relevant to fire assessment, such as furniture, finishes, or contents.</rdfs:comment>
        <rdfs:label xml:lang="en">BuildingContent</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#BuildingSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#BuildingSystem">
        <rdfs:comment xml:lang="en">A building system refers to the interconnected, functional components of a building, including its mechanical, and electrical infrastructure.</rdfs:comment>
        <rdfs:label xml:lang="en">BuildingSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CarParking -->


    <owl:Class rdf:about="https://w3id.org/ficr#CarParking">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#CavityBarrier -->


    <owl:Class rdf:about="https://w3id.org/ficr#CavityBarrier">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:comment xml:lang="en">A construction within a cavity, other than a smoke curtain, to perform either of the
following functions.
• Close a cavity to stop smoke or flame entering.
• Restrict the movement of smoke or flame within a cavity.</rdfs:comment>
        <rdfs:label xml:lang="en">CavityBarrier</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CavityBarrierPerformanceAspect -->


    <owl:Class rdf:about="https://w3id.org/ficr#CavityBarrierPerformanceAspect">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BoundaryPerformanceAspect"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#CavitySpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#CavitySpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#DuctSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoofSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoomSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">A space enclosed by elements of a building (including a suspended ceiling) or contained within an element, but that is not a room, cupboard, circulation space, protected shaft, or space within a flue, chute, duct, pipe or conduit.</rdfs:comment>
        <rdfs:label xml:lang="en">CavitySpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Ceiling -->


    <owl:Class rdf:about="https://w3id.org/ficr#Ceiling">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">Part of a building that encloses a room, protected shaft or circulation space and is exposed overhead.
The soffit of a rooflight, but not the frame, is included as part of the surface of the ceiling. An upstand below a rooflight is considered as a wall.</rdfs:comment>
        <rdfs:label xml:lang="en">Ceiling</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CertificateEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#CertificateEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#DocumentEvidence"/>
        <rdfs:comment xml:lang="en">A document evidence item representing a certificate that supports an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">CertificateEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Circuit -->


    <owl:Class rdf:about="https://w3id.org/ficr#Circuit">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ElectricalSystem"/>
        <rdfs:comment xml:lang="en">A continuous pathway that allows electricity to flow from the main supply (consumer unit) to various outlets, lights, or appliances, and back again.</rdfs:comment>
        <rdfs:label xml:lang="en">Circuit</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CirculationSpaceRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#CirculationSpaceRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#CirculationUsage -->


    <owl:Class rdf:about="https://w3id.org/ficr#CirculationUsage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Gallery"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#HabitableRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Kitchen"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Cladding -->


    <owl:Class rdf:about="https://w3id.org/ficr#Cladding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ExternalWall"/>
        <rdfs:comment xml:lang="en">Cladding is an external layer applied to a building&apos;s structure to provide weather protection, thermal insulation, and improved aesthetics.</rdfs:comment>
        <rdfs:label xml:lang="en">Cladding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Classification -->


    <owl:Class rdf:about="https://w3id.org/ficr#Classification">
        <rdfs:comment xml:lang="en">Classify buildings or compartments according to their intended use, construction type, or structural risk to ensure safety, regulatory compliance, and facilitate communication between professionals such as planners, insurers, and contractors.</rdfs:comment>
        <rdfs:label xml:lang="en">Classification</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Closing -->


    <owl:Class rdf:about="https://w3id.org/ficr#Closing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">A fabric element category for components that close openings in the building envelope or internal partitions, including doors, windows, and dampers.</rdfs:comment>
        <rdfs:label xml:lang="en">Closing</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Column -->


    <owl:Class rdf:about="https://w3id.org/ficr#Column">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#StructuralElement"/>
        <rdfs:comment xml:lang="en">A column is a vertical structural element in a building that supports loads from above and transfers them down to the foundation.</rdfs:comment>
        <rdfs:label xml:lang="en">Column</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CommercialPlace -->


    <owl:Class rdf:about="https://w3id.org/ficr#CommercialPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#CompartmentFloor -->


    <owl:Class rdf:about="https://w3id.org/ficr#CompartmentFloor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Floor"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#FireSeparatingRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Floor"/>
        <rdfs:comment xml:lang="en">A fire resisting floor to separate one fire compartment from another.</rdfs:comment>
        <rdfs:label xml:lang="en">CompartmentFloor</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CompartmentWall -->


    <owl:Class rdf:about="https://w3id.org/ficr#CompartmentWall">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Wall"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#FireSeparatingRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Wall"/>
        <rdfs:comment xml:lang="en">A fire resisting wall to separate one fire compartment from another.
including a wall that is common to two or more buildings.</rdfs:comment>
        <rdfs:label xml:lang="en">CompartmentWall</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CompartmentationPerformanceAspect -->


    <owl:Class rdf:about="https://w3id.org/ficr#CompartmentationPerformanceAspect">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BoundaryPerformanceAspect"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ComplianceChecking -->


    <owl:Class rdf:about="https://w3id.org/ficr#ComplianceChecking">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ficr#producesFinding"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ficr#ComplianceFinding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An assessment that checks whether fire-related requirements are satisfied. It produces compliance findings rather than storing a single assessment-level result.</rdfs:comment>
        <rdfs:label xml:lang="en">ComplianceChecking</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ComplianceCheckingTask -->


    <owl:Class rdf:about="https://w3id.org/ficr#ComplianceCheckingTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:comment xml:lang="en">A task that evaluates one or more requirements against available evidence and produces a compliance result.</rdfs:comment>
        <rdfs:label xml:lang="en">ComplianceCheckingTask</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ComplianceFinding -->


    <owl:Class rdf:about="https://w3id.org/ficr#ComplianceFinding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#InspectionFinding"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RiskFinding"/>
        <rdfs:comment xml:lang="en">An assessment finding produced by compliance checking. It records the assessed item, applicable requirement, actual value or condition, required value or criterion, compliance result, evidence status, and regulatory basis where available.</rdfs:comment>
        <rdfs:label xml:lang="en">ComplianceFinding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ComplianceRequestTriggerEvent -->


    <owl:Class rdf:about="https://w3id.org/ficr#ComplianceRequestTriggerEvent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Event"/>
        <rdfs:comment xml:lang="en">A trigger event created when a compliance request is received from an external authority, or when a prior task identifies missing evidence or unmet preconditions requiring follow-up inspection or assessment.</rdfs:comment>
        <rdfs:label xml:lang="en">ComplianceRequestTriggerEvent</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ComplianceResult -->


    <owl:Class rdf:about="https://w3id.org/ficr#ComplianceResult">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentState"/>
        <rdfs:comment xml:lang="en">A controlled assessment state representing the result of a compliance finding, such as compliant, non-compliant, or undetermined. Compliance results are attached to ComplianceFinding records so that they remain traceable to the assessed target, checked requirement, evidence status, and regulatory source.</rdfs:comment>
        <rdfs:label xml:lang="en">ComplianceResult</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#CompliantResult -->


    <owl:Class rdf:about="https://w3id.org/ficr#CompliantResult">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ComplianceResult"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NonCompliantResult"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#UndeterminedResult"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Compromised -->


    <owl:Class rdf:about="https://w3id.org/ficr#Compromised">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ConditionState"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Effective"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Unknown"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ConditionState -->


    <owl:Class rdf:about="https://w3id.org/ficr#ConditionState">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentState"/>
        <rdfs:comment xml:lang="en">Physical performance status assessment of boundary condition state.</rdfs:comment>
        <rdfs:label xml:lang="en">ConditionState</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Controller -->


    <owl:Class rdf:about="https://w3id.org/ficr#Controller">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Equipment"/>
        <rdfs:comment xml:lang="en">In buildings, a &quot;controller&quot; is the &quot;brain&quot; of an automated system, receiving data from sensors and sending commands to devices like HVAC, lighting, and alarms to ensure comfort and efficiency.</rdfs:comment>
        <rdfs:label xml:lang="en">Controller</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Corridor -->


    <owl:Class rdf:about="https://w3id.org/ficr#Corridor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EntranceHall"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Foyer"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Hall"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Lobby"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Curtain -->


    <owl:Class rdf:about="https://w3id.org/ficr#Curtain">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">Part of a solar shading device which is set in motion by the operating system and fulfils the purpose of a blind, awning or shutter.</rdfs:comment>
        <rdfs:label xml:lang="en">Curtain</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#DeadEndRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#DeadEndRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#DeficiencyFinding -->


    <owl:Class rdf:about="https://w3id.org/ficr#DeficiencyFinding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#InspectionFinding"/>
        <rdfs:comment xml:lang="en">An inspection finding that records an observed defect, shortfall, obstruction, damage, missing evidence, or other adverse condition relevant to fire-related O&amp;M assessment.</rdfs:comment>
        <rdfs:label xml:lang="en">DeficiencyFinding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#DetentionHouse -->


    <owl:Class rdf:about="https://w3id.org/ficr#DetentionHouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#DocumentEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#DocumentEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">An external file or record that supports assessment or documentation, such as product data sheets, installation manuals, certificates, drawings, or inspection reports. It is linked for human access and traceability and does not directly participate in logical inference unless explicitly modelled.</rdfs:comment>
        <rdfs:label xml:lang="en">DocumentEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Doorset -->


    <owl:Class rdf:about="https://w3id.org/ficr#Doorset">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Closing"/>
        <rdfs:comment xml:lang="en">A doorset is a complete, integrated door system consisting of the door leaf, frame, and all necessary hardware like hinges, seals, and closers, sold as a single unit from one source.</rdfs:comment>
        <rdfs:label xml:lang="en">Doorset</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#DrawingEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#DrawingEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#DocumentEvidence"/>
        <rdfs:comment xml:lang="en">A document evidence item representing a drawing that supports an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">DrawingEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#DuctSpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#DuctSpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoofSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoomSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">A duct space is a designated area or channel within a building that houses the systems for conveying air, cables, and other utilities.</rdfs:comment>
        <rdfs:label xml:lang="en">DuctSpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Dwellinghouse -->


    <owl:Class rdf:about="https://w3id.org/ficr#Dwellinghouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Effective -->


    <owl:Class rdf:about="https://w3id.org/ficr#Effective">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ConditionState"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Unknown"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ElectricalSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#ElectricalSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">An electrical system in a building is a network of wiring, equipment, and protective devices that safely distributes power from its entry point to all the loads, such as lights, outlets, and appliances, within the structure.</rdfs:comment>
        <rdfs:label xml:lang="en">ElectricalSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EmergencyLightingSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#EmergencyLightingSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">A protection system that provides lighting for escape routes, safety equipment, or relevant spaces when normal lighting fails.</rdfs:comment>
        <rdfs:label xml:lang="en">EmergencyLightingSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EngineRoom -->


    <owl:Class rdf:about="https://w3id.org/ficr#EngineRoom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#FuelStorage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#SwitchGearRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#TransformerRoom"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#EntertainmentPlace -->


    <owl:Class rdf:about="https://w3id.org/ficr#EntertainmentPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#EntranceHall -->


    <owl:Class rdf:about="https://w3id.org/ficr#EntranceHall">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Foyer"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Hall"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Lobby"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Equipment -->


    <owl:Class rdf:about="https://w3id.org/ficr#Equipment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Element"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">An independently identifiable and maintainable physical device or apparatus. Equipment is modelled as ficr:PhysicalObject and aligned with bot:Element when it is located in or associated with the building topology.</rdfs:comment>
        <rdfs:label xml:lang="en">Equipment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EquipmentInspectionTask -->


    <owl:Class rdf:about="https://w3id.org/ficr#EquipmentInspectionTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:comment xml:lang="en">Inspection task consumes observations produced by upstream tools.</rdfs:comment>
        <rdfs:label xml:lang="en">EquipmentInspectionTask</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EscapeAndEvacuationRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#EscapeAndEvacuationRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">A fire safety role related to escape, evacuation, exits, access rooms, protected routes, dead ends, circulation spaces, or other route-related fire-safety interpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">EscapeAndEvacuationRole</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EscapeLighting -->


    <owl:Class rdf:about="https://w3id.org/ficr#EscapeLighting">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EmergencyLightingSystem"/>
        <rdfs:comment xml:lang="en">The part of the emergency lighting that is provided to ensure that the escape route is illuminated at all material times.</rdfs:comment>
        <rdfs:label xml:lang="en">EscapeLighting</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvacuationLift -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvacuationLift">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#LiftSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSystemFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#EvacuationRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSystem"/>
        <rdfs:comment xml:lang="en">A lift that may be used to evacuate people in a fire.</rdfs:comment>
        <rdfs:label xml:lang="en">EvacuationLift</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvacuationRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvacuationRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Event -->


    <owl:Class rdf:about="https://w3id.org/ficr#Event">
        <rdfs:comment xml:lang="en">An occurrence that triggers the creation of one or more tasks in the FiCR workflow, such as a routine schedule, an anomaly alert, or a compliance request.</rdfs:comment>
        <rdfs:label xml:lang="en">Event</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvidenceAvailable -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvidenceAvailable">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EvidenceInsufficient"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EvidenceMissing"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EvidenceNotRequired"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvidenceInsufficient -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvidenceInsufficient">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EvidenceMissing"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EvidenceNotRequired"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvidenceItem -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvidenceItem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentBasis"/>
        <rdfs:comment xml:lang="en">A single piece of evidence that supports an assessment. It may be an observation, a regulatory reference, or an external document. Evidence items are linkable, traceable, and can be attached to specific assets, spaces, or checks.</rdfs:comment>
        <rdfs:label xml:lang="en">EvidenceItem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvidenceMissing -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvidenceMissing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#EvidenceNotRequired"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvidenceNotRequired -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvidenceNotRequired">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceStatus"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#EvidenceStatus -->


    <owl:Class rdf:about="https://w3id.org/ficr#EvidenceStatus">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentState"/>
        <rdfs:comment xml:lang="en">A controlled assessment state describing whether the evidence required to support an assessment finding or boundary condition record is available, missing, insufficient, or not required.</rdfs:comment>
        <rdfs:label xml:lang="en">EvidenceStatus</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ExitPassagewayRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#ExitPassagewayRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ExternalFireSpreadPerformanceAspect -->


    <owl:Class rdf:about="https://w3id.org/ficr#ExternalFireSpreadPerformanceAspect">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BoundaryPerformanceAspect"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ExternalWall -->


    <owl:Class rdf:about="https://w3id.org/ficr#ExternalWall">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Wall"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#isExternal"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Wall"/>
        <rdfs:comment xml:lang="en">The external wall of a building includes all of the following.
• Anything located within any space forming part of the wall.
• Any decoration or other finish applied to any external (but not internal) surface forming part of the wall.
• Any windows and doors in the wall.
• Any part of a roof pitched at an angle of more than 70 degrees to the horizontal if that part of the roof adjoins a space within the building to which persons have access, but not access only for the purpose of carrying out repairs or maintenance.</rdfs:comment>
        <rdfs:label xml:lang="en">ExternalWall</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ExternalWallDoor -->


    <owl:Class rdf:about="https://w3id.org/ficr#ExternalWallDoor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Doorset"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#isExternal"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Doorset"/>
        <rdfs:comment xml:lang="en">An external wall door is a door that is part of a building&apos;s exterior wall, providing an entrance and exit to the building.</rdfs:comment>
        <rdfs:label xml:lang="en">ExternalWallDoor</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ExternalWallWindow -->


    <owl:Class rdf:about="https://w3id.org/ficr#ExternalWallWindow">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Window"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#isExternal"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Window"/>
        <rdfs:comment xml:lang="en">An external wall window is a window that is part of a building&apos;s exterior wall, which acts as the outer boundary separating the interior from the outside environment.</rdfs:comment>
        <rdfs:label xml:lang="en">ExternalWallWindow</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FabricElement -->


    <owl:Class rdf:about="https://w3id.org/ficr#FabricElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Element"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">A physical construction element forming part of the building fabric. Fabric elements are modelled as ficr:PhysicalObject and aligned with bot:Element so that they can participate in spatial containment, adjacency, and fire-related classification.</rdfs:comment>
        <rdfs:label xml:lang="en">FabricElement</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Factory -->


    <owl:Class rdf:about="https://w3id.org/ficr#Factory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#FinalExitRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FinalExitRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Finishes -->


    <owl:Class rdf:about="https://w3id.org/ficr#Finishes">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingContent"/>
        <rdfs:comment xml:lang="en">Finishes are the final surface treatments and decorative elements applied to a building&apos;s interior and exterior.</rdfs:comment>
        <rdfs:label xml:lang="en">Finishes</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireAlarmSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireAlarmSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSystem"/>
        <rdfs:comment xml:lang="en">A system-level arrangement of components for detecting fire and giving audible, visual, or other perceptible warning of fire.</rdfs:comment>
        <rdfs:label xml:lang="en">FireAlarmSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireAndSmokeDamper -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireAndSmokeDamper">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireDamper"/>
        <rdfs:comment xml:lang="en">A fire damper which, in addition to the performance of the fire damper, resists the spread of smoke.</rdfs:comment>
        <rdfs:label xml:lang="en">FireAndSmokeDamper</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireCompartment -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireCompartment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Zone"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/bot#adjacentElement"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#CompartmentFloor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/bot#adjacentElement"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#CompartmentWall"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSpatialProvision"/>
        <rdfs:comment xml:lang="en">A fire safety space bounded by compartment walls and compartment floors, designed to prevent the spread of fire and smoke beyond the compartment of origin.</rdfs:comment>
        <rdfs:label xml:lang="en">FireCompartment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireDamper -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireDamper">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Closing"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#FireResistingRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Closing"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:comment xml:lang="en">A mechanical or intumescent device within a duct or ventilation opening that operates automatically and is designed to resist the spread of fire.</rdfs:comment>
        <rdfs:label xml:lang="en">FireDamper</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireDoorset -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireDoorset">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Doorset"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#FireResistingRole"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#FireSeparatingRole"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Doorset"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:comment xml:lang="en">A door or shutter which, together with its frame and furniture as installed in a building, is intended (when closed) to resist the spread of fire and/or gaseous products of combustion and meets specified performance criteria to those ends.</rdfs:comment>
        <rdfs:label xml:lang="en">FireDoorset</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireExtinguisher -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireExtinguisher">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionEquipment"/>
        <rdfs:comment xml:lang="en">A portable or fixed manually-operated device containing an extinguishing agent that can be expelled for the purpose of suppressing or extinguishing a fire. Fire extinguishers are classified by their agent type (water, foam, CO2, dry powder, wet chemical) and by the fire classes they are rated to address.</rdfs:comment>
        <rdfs:label xml:lang="en">FireExtinguisher</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireFightingLift -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireFightingLift">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#LiftSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSystemFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#FirefightingRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSystem"/>
        <rdfs:comment xml:lang="en">A lift with additional protection and with controls that enable it to be used by the fire and rescue service when fighting a fire.</rdfs:comment>
        <rdfs:label xml:lang="en">FireFightingLift</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireProtectionElement -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireProtectionElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionProvision"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PhysicalObject"/>
        <rdfs:comment xml:lang="en">A physical object, building element, or component that contributes to fire protection performance. This class groups physical fire-protection provisions while preserving their identity through more specific classes such as wall, doorset, stair, damper, cavity barrier, or fire stop.</rdfs:comment>
        <rdfs:label xml:lang="en">FireProtectionElement</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireProtectionEquipment -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireProtectionEquipment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Equipment"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionProvision"/>
        <rdfs:comment xml:lang="en">A maintainable equipment item that supports fire protection or fire safety operation, such as warning, detection, suppression, release, control, manual firefighting, monitoring, or activation. Equipment-level provisions remain distinct from system-level provisions.</rdfs:comment>
        <rdfs:label xml:lang="en">FireProtectionEquipment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireProtectionProvision -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireProtectionProvision">
        <rdfs:comment xml:lang="en">A building element, equipment item, system, component, or spatial arrangement that is provided or designated to support fire protection or fire safety performance. This class is used as a common query target for fire-related provisions without treating all of them as building systems.</rdfs:comment>
        <rdfs:label xml:lang="en">FireProtectionProvision</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireProtectionRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireProtectionRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">A fire safety role related to active or passive fire protection, fire separation, fire resistance, or limitation of fire spread.</rdfs:comment>
        <rdfs:label xml:lang="en">FireProtectionRole</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireProtectionSpatialProvision -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireProtectionSpatialProvision">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionProvision"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireSafetySpace"/>
        <rdfs:comment xml:lang="en">A spatial zone or arrangement that contributes to fire protection or fire safety performance, such as a compartment, protected corridor, protected lobby, protected shaft, protected stairway space, or other protected escape or separation space.</rdfs:comment>
        <rdfs:label xml:lang="en">FireProtectionSpatialProvision</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireProtectionSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireProtectionSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionProvision"/>
        <rdfs:comment xml:lang="en">A distributed or system-level building system that supports fire protection or fire safety operation, including detection, alarm, suppression, smoke control, emergency lighting, protected electrical supply, firefighting support, or evacuation support.</rdfs:comment>
        <rdfs:label xml:lang="en">FireProtectionSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireResistingRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireResistingRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireRiskAssessmentTask -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireRiskAssessmentTask">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Task"/>
        <rdfs:comment xml:lang="en">A task that produces a fire risk analysis assessment for O&amp;M use. It supports risk-informed interpretation by linking risk units, fire risk scenarios, compliance findings, boundary condition records, condition states, and evidence status.</rdfs:comment>
        <rdfs:label xml:lang="en">FireRiskAssessmentTask</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireRiskScenario -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireRiskScenario">
        <rdfs:comment xml:lang="en">A hypothetical fire scenario anchored to an origin space or zone. It describes the fire origin, relevant spread context, affected risk unit, and boundary conditions used for risk-informed O&amp;M interpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">FireRiskScenario</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireSafetyRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireSafetyRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UsageType"/>
        <rdfs:comment xml:lang="en">A controlled role or designation assigned to a physical object, spatial zone, or building system to describe its fire-safety function. The role itself is independent of the assignment target; the assignment context is expressed by the property used, such as hasPhysicalObjectFireSafetyRole, hasZoneFireSafetyRole, or hasSystemFireSafetyRole.</rdfs:comment>
        <rdfs:label xml:lang="en">FireSafetyRole</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireSafetySpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireSafetySpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">&quot;Fire safety space&quot; in a building refers to the areas designed to prevent the spread of fire and smoke and guide occupants to safety.</rdfs:comment>
        <rdfs:label xml:lang="en">FireSafetySpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireSeparatingRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireSeparatingRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireSprinklerSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireSprinklerSystem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#PipingSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSystemFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#ActiveFireProtectionRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSystem"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PipingSystem"/>
        <rdfs:comment xml:lang="en">A fire protection system that uses a network of pipes, control components, and sprinkler outlets to discharge water for fire suppression or control.</rdfs:comment>
        <rdfs:label xml:lang="en">FireSprinklerSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FireStop -->


    <owl:Class rdf:about="https://w3id.org/ficr#FireStop">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:comment xml:lang="en">A seal provided to close an imperfection of fit or design tolerance between elements or components, to restrict the spread of fire and smoke.</rdfs:comment>
        <rdfs:label xml:lang="en">FireStop</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FirefightingRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FirefightingRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FirefightingSupportRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#FirefightingSupportRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#FirefightingSupportRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireSafetyRole"/>
        <rdfs:comment xml:lang="en">A fire safety role related to firefighter access, firefighting support, fire service intervention, or systems and spaces designated to support firefighting operations.</rdfs:comment>
        <rdfs:label xml:lang="en">FirefightingSupportRole</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Flat -->


    <owl:Class rdf:about="https://w3id.org/ficr#Flat">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Floor -->


    <owl:Class rdf:about="https://w3id.org/ficr#Floor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">A floor is the horizontal surface in a building that forms the base of a room, providing structural support for occupants, furniture, and the building&apos;s own weight.</rdfs:comment>
        <rdfs:label xml:lang="en">Floor</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#FloorSlab -->


    <owl:Class rdf:about="https://w3id.org/ficr#FloorSlab">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Floor"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Slab"/>
        <rdfs:comment xml:lang="en">A horizontal structural slab forming an intermediate or ground-level floor, transferring occupancy and dead loads to the supporting structure.</rdfs:comment>
        <rdfs:label xml:lang="en">FloorSlab</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Foyer -->


    <owl:Class rdf:about="https://w3id.org/ficr#Foyer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Hall"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Lobby"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#FuelStorage -->


    <owl:Class rdf:about="https://w3id.org/ficr#FuelStorage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#SwitchGearRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#TransformerRoom"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Furnishings -->


    <owl:Class rdf:about="https://w3id.org/ficr#Furnishings">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingContent"/>
        <rdfs:comment xml:lang="en">Movable items that make a space habitable and decorative.</rdfs:comment>
        <rdfs:label xml:lang="en">Furnishings</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Gallery -->


    <owl:Class rdf:about="https://w3id.org/ficr#Gallery">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#HabitableRoom"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Kitchen"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#GroundAndAboveStorey -->


    <owl:Class rdf:about="https://w3id.org/ficr#GroundAndAboveStorey">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Storey"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#isAboveGround"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Storey"/>
        <rdfs:comment xml:lang="en">A storey at or above ground level, defined by isAboveGround = true.</rdfs:comment>
        <rdfs:label xml:lang="en">GroundAndAboveStorey</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#GuidanceDocument -->


    <owl:Class rdf:about="https://w3id.org/ficr#GuidanceDocument">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:comment xml:lang="en">Guidance documents explaining how to meet requirements or how to conduct assessments are not necessarily laws in themselves.</rdfs:comment>
        <rdfs:label xml:lang="en">GuidanceDocument</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#HVACSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#HVACSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">An HVAC system is a building&apos;s climate control system for heating, ventilation, and air conditioning.</rdfs:comment>
        <rdfs:label xml:lang="en">HVACSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#HabitableRoom -->


    <owl:Class rdf:about="https://w3id.org/ficr#HabitableRoom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Kitchen"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Hall -->


    <owl:Class rdf:about="https://w3id.org/ficr#Hall">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Lobby"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#HallOfResidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#HallOfResidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Hospital -->


    <owl:Class rdf:about="https://w3id.org/ficr#Hospital">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Hostel -->


    <owl:Class rdf:about="https://w3id.org/ficr#Hostel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Hotel -->


    <owl:Class rdf:about="https://w3id.org/ficr#Hotel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Impaired -->


    <owl:Class rdf:about="https://w3id.org/ficr#Impaired">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ImpairmentState"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ImpairmentUnknown"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Operational"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ImpairmentState -->


    <owl:Class rdf:about="https://w3id.org/ficr#ImpairmentState">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentState"/>
        <rdfs:comment xml:lang="en">ImpairmentState of the building component.</rdfs:comment>
        <rdfs:label xml:lang="en">ImpairmentState</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ImpairmentUnknown -->


    <owl:Class rdf:about="https://w3id.org/ficr#ImpairmentUnknown">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ImpairmentState"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Operational"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#InnerRoomRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#InnerRoomRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#InspectionAssessment -->


    <owl:Class rdf:about="https://w3id.org/ficr#InspectionAssessment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ficr#producesFinding"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ficr#InspectionFinding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An assessment activity that evaluates fire safety or compliance conditions through inspection.</rdfs:comment>
        <rdfs:label xml:lang="en">InspectionAssessment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#InspectionFinding -->


    <owl:Class rdf:about="https://w3id.org/ficr#InspectionFinding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RiskFinding"/>
        <rdfs:comment xml:lang="en">An assessment finding produced by inspection activity. It records observed fire-related conditions, deficiencies, evidence gaps, or verification outcomes relevant to O&amp;M assessment.</rdfs:comment>
        <rdfs:label xml:lang="en">InspectionFinding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#InspectionReportEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#InspectionReportEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#DocumentEvidence"/>
        <rdfs:comment xml:lang="en">A document evidence item representing an inspection report that supports an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">InspectionReportEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#InstallationNotRequired -->


    <owl:Class rdf:about="https://w3id.org/ficr#InstallationNotRequired">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#InstallationStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#InstallationUnknown"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Installed"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NotInstalled"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PartiallyInstalled"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#InstallationStatus -->


    <owl:Class rdf:about="https://w3id.org/ficr#InstallationStatus">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentState"/>
        <rdfs:comment xml:lang="en">Whether a fire safety system or component is installed, and if so, to what specification.</rdfs:comment>
        <rdfs:label xml:lang="en">InstallationStatus</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#InstallationUnknown -->


    <owl:Class rdf:about="https://w3id.org/ficr#InstallationUnknown">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#InstallationStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Installed"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NotInstalled"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PartiallyInstalled"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Installed -->


    <owl:Class rdf:about="https://w3id.org/ficr#Installed">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#InstallationStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NotInstalled"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PartiallyInstalled"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Kitchen -->


    <owl:Class rdf:about="https://w3id.org/ficr#Kitchen">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#LiftShaft -->


    <owl:Class rdf:about="https://w3id.org/ficr#LiftShaft">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <rdfs:comment xml:lang="en">A lift shaft is a vertical passageway in a building where an elevator travels between floors.</rdfs:comment>
        <rdfs:label xml:lang="en">LiftShaft</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#LiftSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#LiftSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#VerticalTransportSystem"/>
        <rdfs:comment xml:lang="en">Complete machinery and infrastructure for vertical transport.</rdfs:comment>
        <rdfs:label xml:lang="en">LiftSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Lobby -->


    <owl:Class rdf:about="https://w3id.org/ficr#Lobby">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#CirculationUsage"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#MaintenanceRecordEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#MaintenanceRecordEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#DocumentEvidence"/>
        <rdfs:comment xml:lang="en">A document evidence item representing a maintenance record that supports an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">MaintenanceRecordEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#MeansOfEscapeRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#MeansOfEscapeRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#MultiStoreyBuilding -->


    <owl:Class rdf:about="https://w3id.org/ficr#MultiStoreyBuilding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Building"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#SingleStoreyBuilding"/>
        <rdfs:comment xml:lang="en">The building is regarded as a multi-storey building if both of the following apply.
• There is more than one gallery.
• The total aggregate area of all the galleries in one space is more than half the floor area of that space.</rdfs:comment>
        <rdfs:label xml:lang="en">MultiStoreyBuilding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#NonCompliantResult -->


    <owl:Class rdf:about="https://w3id.org/ficr#NonCompliantResult">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ComplianceResult"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#UndeterminedResult"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#NotApplicable -->


    <owl:Class rdf:about="https://w3id.org/ficr#NotApplicable">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ApplicabilityState"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#NotAssessed"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#NotAssessed -->


    <owl:Class rdf:about="https://w3id.org/ficr#NotAssessed">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ApplicabilityState"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#NotInstalled -->


    <owl:Class rdf:about="https://w3id.org/ficr#NotInstalled">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#InstallationStatus"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#PartiallyInstalled"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ObservedEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#ObservedEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">Evidence collected from the building or its digital sensors during inspection or monitoring, such as RGB images, depth, LiDAR/point clouds, and sensor readings. This class represents the content used for assessment, not the provenance metadata standard itself.</rdfs:comment>
        <rdfs:label xml:lang="en">ObservedEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Office -->


    <owl:Class rdf:about="https://w3id.org/ficr#Office">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Opening -->


    <owl:Class rdf:about="https://w3id.org/ficr#Opening">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">Refers to any intentional void in walls, floors, or ceilings for access, light, air, or services, such as doors, windows, ducts, or stairwells.</rdfs:comment>
        <rdfs:label xml:lang="en">Opening</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Operational -->


    <owl:Class rdf:about="https://w3id.org/ficr#Operational">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ImpairmentState"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PartiallyInstalled -->


    <owl:Class rdf:about="https://w3id.org/ficr#PartiallyInstalled">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#InstallationStatus"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PassiveFireProtectionRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#PassiveFireProtectionRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PhotographEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#PhotographEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#DocumentEvidence"/>
        <rdfs:comment xml:lang="en">A document evidence item representing a photograph that supports an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">PhotographEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PhysicalObject -->


    <owl:Class rdf:about="https://w3id.org/ficr#PhysicalObject">
        <rdfs:comment xml:lang="en">A tangible object relevant to fire-related assessment. A physical object may be a building element, equipment item, or building content. Only those physical objects that participate in the building topology are aligned with bot:Element.</rdfs:comment>
        <rdfs:label xml:lang="en">PhysicalObject</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PipingSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#PipingSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">A building system composed of pipes, fittings, valves, and related components for conveying water, gas, or other fluids within or through a building.</rdfs:comment>
        <rdfs:label xml:lang="en">PipingSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PlaceOfSpecialHazard -->


    <owl:Class rdf:about="https://w3id.org/ficr#PlaceOfSpecialHazard">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ServiceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedCircuit -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedCircuit">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Circuit"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSystemFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSystem"/>
        <rdfs:comment xml:lang="en">An electrical circuit that is protected against fire.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedCircuit</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedCorridor -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedCorridor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Zone"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasZoneFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSpaceUsage"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ficr#Corridor"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSpatialProvision"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedEntranceHall"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedLobby"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedShaft"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedStairwaySpace"/>
        <rdfs:comment xml:lang="en">A corridor that is adequately protected from fire in adjoining areas by fire resisting construction.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedCorridor</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedEntranceHall -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedEntranceHall">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Zone"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasZoneFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSpaceUsage"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ficr#EntranceHall"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSpatialProvision"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedLobby"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedShaft"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedStairwaySpace"/>
        <rdfs:comment xml:lang="en">A circulation area, consisting of a hall or space in a flat, that is enclosed with fire resisting construction other than an external wall of a building.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedEntranceHall</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedLobby -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedLobby">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Zone"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasZoneFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasSpaceUsage"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ficr#Lobby"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSpatialProvision"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedShaft"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedStairwaySpace"/>
        <rdfs:comment xml:lang="en">A corridor or lobby that is adequately protected from fire in adjoining areas by fire resisting construction.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedLobby</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedShaft -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedShaft">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Zone"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#containsSystem"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#VerticalTransportSystem"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasZoneFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSpatialProvision"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ProtectedStairwaySpace"/>
        <rdfs:comment xml:lang="en">A shaft that enables people, air or objects to pass from one compartment to another, and which is enclosed with fire resisting construction.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedShaft</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedStairway -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedStairway">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ficr#Stair"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasPhysicalObjectFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionElement"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Stair"/>
        <rdfs:comment xml:lang="en">A stair that leads to a final exit to a place of safety and that is adequately enclosed with fire resisting construction. Included in the definition is any exit passageway between the foot of the stair and the final exit.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedStairway</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ProtectedStairwaySpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#ProtectedStairwaySpace">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Zone"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/bot#containsElement"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#Stair"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#hasZoneFireSafetyRole"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#PassiveFireProtectionRole"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionSpatialProvision"/>
        <rdfs:comment xml:lang="en">A stairway space that leads to a final exit to a place of safety and that is adequately enclosed with fire resisting construction. Included in the definition is any exit passageway between the foot of the stair and the final exit.</rdfs:comment>
        <rdfs:label xml:lang="en">ProtectedStairwaySpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#RegulatoryClassification"/>
        <rdfs:comment xml:lang="en">Classification of a building or compartment by its intended use according to ADB Table 0.1.</rdfs:comment>
        <rdfs:label xml:lang="en">PurposeGroup</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup1 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup1">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
        <rdfs:comment xml:lang="en">A dwelling is a unit where one or more people live (whether or not as a sole or main residence) in either of the following situations.
• A single person or people living together as a family.
• A maximum of six people living together as a single household, including where care is provided for residents.</rdfs:comment>
        <rdfs:label xml:lang="en">PurposeGroup1</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup1a -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup1a">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup1"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup1b -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup1b">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup1"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup1c -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup1c">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup1"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup2 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup2">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
        <rdfs:comment xml:lang="en">Residential other than Dwellings.</rdfs:comment>
        <rdfs:label xml:lang="en">PurposeGroup2</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup2a -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup2a">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup2"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup2b -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup2b">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup2"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup3 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup3">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup4 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup4">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup5 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup5">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup6 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup6">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup7 -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup7">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup"/>
        <rdfs:comment xml:lang="en">Storage and Car Parking</rdfs:comment>
        <rdfs:label xml:lang="en">PurposeGroup7</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup7a -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup7a">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup7"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#PurposeGroup7b -->


    <owl:Class rdf:about="https://w3id.org/ficr#PurposeGroup7b">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PurposeGroup7"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Railing -->


    <owl:Class rdf:about="https://w3id.org/ficr#Railing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">A railing refers to a protective barrier or fence, usually made of metal (such as wrought or cast iron, steel, or aluminium), timber, or plastic, designed to provide safety and support.</rdfs:comment>
        <rdfs:label xml:lang="en">Railing</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RegulatoryClassification -->


    <owl:Class rdf:about="https://w3id.org/ficr#RegulatoryClassification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Classification"/>
        <rdfs:comment xml:lang="en">A classification derived from a regulatory source and used to organise compliance requirements or assessment criteria.</rdfs:comment>
        <rdfs:label xml:lang="en">RegulatoryClassification</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RegulatoryInstrument -->


    <owl:Class rdf:about="https://w3id.org/ficr#RegulatoryInstrument">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:comment xml:lang="en">Laws, regulations, and regulatory documents with statutory binding force.</rdfs:comment>
        <rdfs:label xml:lang="en">RegulatoryInstrument</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RegulatoryRequirement -->


    <owl:Class rdf:about="https://w3id.org/ficr#RegulatoryRequirement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#RequirementSpecification"/>
        <rdfs:comment xml:lang="en">A requirement specification derived from a regulatory, standards, or guidance source. It records the applicable scope, required value or criterion, clause reference, jurisdiction, and source traceability.</rdfs:comment>
        <rdfs:label xml:lang="en">RegulatoryRequirement</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RegulatorySource -->


    <owl:Class rdf:about="https://w3id.org/ficr#RegulatorySource">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentBasis"/>
        <rdfs:comment xml:lang="en">A referenced regulatory or standards document used as the normative basis for a check or requirement, such as Approved Document B, BDM02, or related standards. It provides the requirement context and should be versioned where possible.</rdfs:comment>
        <rdfs:label xml:lang="en">RegulatorySource</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RelevantBoundary -->


    <owl:Class rdf:about="https://w3id.org/ficr#RelevantBoundary">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SiteBoundary"/>
        <rdfs:comment xml:lang="en">The boundary or notional boundary that one side of the building faces and/or coincides with, and that is parallel or at an angle of a maximum of 80 degrees to that side of the building.</rdfs:comment>
        <rdfs:label xml:lang="en">RelevantBoundary</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RequirementSpecification -->


    <owl:Class rdf:about="https://w3id.org/ficr#RequirementSpecification">
        <rdfs:comment xml:lang="en">A structured specification of a requirement, criterion, or threshold used in assessment. Requirement specifications may be derived from regulations, standards, guidance documents, or project-specific assessment criteria.</rdfs:comment>
        <rdfs:label xml:lang="en">RequirementSpecification</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ResidentialCollege -->


    <owl:Class rdf:about="https://w3id.org/ficr#ResidentialCollege">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#RiskAnalysis -->


    <owl:Class rdf:about="https://w3id.org/ficr#RiskAnalysis">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Assessment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ficr#producesFinding"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ficr#RiskFinding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An assessment that supports risk-informed interpretation by using risk units, fire risk scenarios, compliance findings, boundary condition records, condition states, and evidence status. It does not perform full quantitative fire risk calculation in the FiCR core ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">RiskAnalysis</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RiskFinding -->


    <owl:Class rdf:about="https://w3id.org/ficr#RiskFinding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#AssessmentFinding"/>
        <rdfs:comment xml:lang="en">An assessment finding produced by risk analysis. It records risk-relevant interpretation for a risk unit, scenario, element, system, or zone, using compliance findings, boundary condition records, and evidence status as inputs.</rdfs:comment>
        <rdfs:label xml:lang="en">RiskFinding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RiskUnit -->


    <owl:Class rdf:about="https://w3id.org/ficr#RiskUnit">
        <rdfs:comment xml:lang="en">A spatial or operational aggregation unit used for fire risk interpretation, evidence-gap review, and inspection prioritisation during O&amp;M. A risk unit may correspond to a dwelling unit, compartment, floor area, tenancy, fire area, or other assessment-defined unit.</rdfs:comment>
        <rdfs:label xml:lang="en">RiskUnit</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Roof -->


    <owl:Class rdf:about="https://w3id.org/ficr#Roof">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">A roof is the top covering of a building that provides protection from the elements like rain, sun, snow, and wind.</rdfs:comment>
        <rdfs:label xml:lang="en">Roof</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RoofSlab -->


    <owl:Class rdf:about="https://w3id.org/ficr#RoofSlab">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Roof"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Slab"/>
        <rdfs:comment xml:lang="en">A horizontal structural slab forming the topmost floor of a building, directly supporting the roof covering and transferring loads to walls or columns.</rdfs:comment>
        <rdfs:label xml:lang="en">RoofSlab</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RoofSpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#RoofSpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#RoomSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">A roof space is the area inside a building between the ceiling of the top floor and the underside of the roof.</rdfs:comment>
        <rdfs:label xml:lang="en">RoofSpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Rooflight -->


    <owl:Class rdf:about="https://w3id.org/ficr#Rooflight">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Closing"/>
        <rdfs:comment xml:lang="en">A dome light, lantern light, ridge light.</rdfs:comment>
        <rdfs:label xml:lang="en">Rooflight</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RooflightOpening -->


    <owl:Class rdf:about="https://w3id.org/ficr#RooflightOpening">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Opening"/>
        <rdfs:comment xml:lang="en">A skylight, glazed barrel vault or other element to admit daylight through a roof.</rdfs:comment>
        <rdfs:label xml:lang="en">RooflightOpening</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RoomSpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#RoomSpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">An enclosed space within a building that is not used solely as a circulation space. The term includes not only conventional rooms, but also cupboards that are not fittings and large spaces such as warehouses and auditoria. The term does not include cavities such as ducts, ceiling cavities and roof spaces.</rdfs:comment>
        <rdfs:label xml:lang="en">RoomSpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#RoutineTriggerEvent -->


    <owl:Class rdf:about="https://w3id.org/ficr#RoutineTriggerEvent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Event"/>
        <rdfs:comment xml:lang="en">A trigger event generated from routine schedules or planned inspection cycles derived from FiCR maintenance and regulatory schedules, such as monthly fire exit checks.</rdfs:comment>
        <rdfs:label xml:lang="en">RoutineTriggerEvent</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#School -->


    <owl:Class rdf:about="https://w3id.org/ficr#School">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#SelfClosingDevice -->


    <owl:Class rdf:about="https://w3id.org/ficr#SelfClosingDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Closing"/>
        <rdfs:comment xml:lang="en">A device that closes a door, when open at any angle, against a door frame.
NOTE: If the door is in a cavity barrier, rising butt hinges (which are different from the self-closing device mentioned above) are acceptable.</rdfs:comment>
        <rdfs:label xml:lang="en">SelfClosingDevice</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Sensor -->


    <owl:Class rdf:about="https://w3id.org/ficr#Sensor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Equipment"/>
        <rdfs:comment xml:lang="en">A sensor in a building is a device that detects environmental changes and sends data to a control system to manage building functions like lighting, HVAC, and safety.</rdfs:comment>
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#SensorEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#SensorEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">An evidence item generated by a sensor or monitoring device to support an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">SensorEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ServiceShaft -->


    <owl:Class rdf:about="https://w3id.org/ficr#ServiceShaft">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ShaftSpace"/>
        <rdfs:comment xml:lang="en">A service shaft is a vertical passage in a building that houses pipes, cables, and ducts for essential building systems like water, electricity, and ventilation.</rdfs:comment>
        <rdfs:label xml:lang="en">ServiceShaft</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ServiceUsage -->


    <owl:Class rdf:about="https://w3id.org/ficr#ServiceUsage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#Warehouse"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#ShaftSpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#ShaftSpace">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Space"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ficr#containsSystem"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#VerticalTransportSystem"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#StairSpace"/>
        <rdfs:comment xml:lang="en">A smaller, enclosed vertical space extending through multiple floors used for specific building services, such as elevator hoistways, enclosed stairwells, or ducts for plumbing, electrical, or air-conditioning equipment.</rdfs:comment>
        <rdfs:label xml:lang="en">ShaftSpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#ShelteredHousing -->


    <owl:Class rdf:about="https://w3id.org/ficr#ShelteredHousing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Shop -->


    <owl:Class rdf:about="https://w3id.org/ficr#Shop">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#SingleStoreyBuilding -->


    <owl:Class rdf:about="https://w3id.org/ficr#SingleStoreyBuilding">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Building"/>
        <rdfs:comment xml:lang="en">A building that consists of a ground storey only. Basements are not counted as storeys in a building (see Appendix D). A separated part that consists of a ground storey only, with a roof to which access is only provided for repair or maintenance, may be treated as a single storey building.</rdfs:comment>
        <rdfs:label xml:lang="en">SingleStoreyBuilding</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#SiteBoundary -->


    <owl:Class rdf:about="https://w3id.org/ficr#SiteBoundary">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Zone"/>
        <rdfs:comment xml:lang="en">A spatial boundary representing the extent of the site or land associated with a building. This class is not used to represent fire compartment boundaries or boundary condition records.</rdfs:comment>
        <rdfs:label xml:lang="en">SiteBoundary</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Slab -->


    <owl:Class rdf:about="https://w3id.org/ficr#Slab">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#StructuralElement"/>
        <rdfs:comment xml:lang="en">A slab is the thick, structural concrete element (like reinforced concrete) forming a building&apos;s horizontal plane</rdfs:comment>
        <rdfs:label xml:lang="en">Slab</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#SolarShadingDevice -->


    <owl:Class rdf:about="https://w3id.org/ficr#SolarShadingDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpecifiedAttachment"/>
        <rdfs:comment xml:lang="en">A device attached to the external surface of an external wall for reducing heat gain within a building by shading or deflecting sunlight.</rdfs:comment>
        <rdfs:label xml:lang="en">SolarShadingDevice</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#SpaceUsage -->


    <owl:Class rdf:about="https://w3id.org/ficr#SpaceUsage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UsageType"/>
        <rdfs:comment xml:lang="en">Describe the uses of the space.</rdfs:comment>
        <rdfs:label xml:lang="en">SpaceUsage</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#SpecifiedAttachment -->


    <owl:Class rdf:about="https://w3id.org/ficr#SpecifiedAttachment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">Includes any of the following.
• A balcony attached to an external wall.
• A device for reducing heat gain within a building by deflecting sunlight which is attached to an external wall.</rdfs:comment>
        <rdfs:label xml:lang="en">SpecifiedAttachment</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Stair -->


    <owl:Class rdf:about="https://w3id.org/ficr#Stair">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">a stairway (or staircase) is a series of steps connecting different levels in a building, serving as a pedestrian route.</rdfs:comment>
        <rdfs:label xml:lang="en">Stair</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#StairFlight -->


    <owl:Class rdf:about="https://w3id.org/ficr#StairFlight">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">A stair flight (or simply &quot;flight&quot;) refers to an uninterrupted, continuous sequence of stairs (steps/risers) that connect two levels, floors, or intermediate landings.</rdfs:comment>
        <rdfs:label xml:lang="en">StairFlight</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#StairSpace -->


    <owl:Class rdf:about="https://w3id.org/ficr#StairSpace">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/bot#Space"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/bot#containsElement"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ficr#Stair"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/bot#Space"/>
        <rdfs:comment xml:lang="en">A stairway space, also called a stairwell, is the vertical compartment in a building that contains a flight of stairs and the associated landings, hallways, or other areas needed to move between floors.</rdfs:comment>
        <rdfs:label xml:lang="en">StairSpace</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Standard -->


    <owl:Class rdf:about="https://w3id.org/ficr#Standard">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#RegulatorySource"/>
        <rdfs:comment xml:lang="en">Technical standards, codes, or guides issued by standards organizations are typically technical specifications; whether they are mandatory depends on whether they are cited in regulations, contracts, or by an authority.</rdfs:comment>
        <rdfs:label xml:lang="en">Standard</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Storage -->


    <owl:Class rdf:about="https://w3id.org/ficr#Storage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UtilizationPurpose"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#StoreyExitRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#StoreyExitRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EscapeAndEvacuationRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#StructuralElement -->


    <owl:Class rdf:about="https://w3id.org/ficr#StructuralElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FabricElement"/>
        <rdfs:comment xml:lang="en">A structural element is a component of a building that is essential for its stability and for transferring loads to the ground, such as foundations, beams, columns, and load-bearing walls.</rdfs:comment>
        <rdfs:label xml:lang="en">StructuralElement</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#StructuralStabilityPerformanceAspect -->


    <owl:Class rdf:about="https://w3id.org/ficr#StructuralStabilityPerformanceAspect">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BoundaryPerformanceAspect"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#SwitchGearRoom -->


    <owl:Class rdf:about="https://w3id.org/ficr#SwitchGearRoom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ficr#TransformerRoom"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Task -->


    <owl:Class rdf:about="https://w3id.org/ficr#Task">
        <rdfs:comment xml:lang="en">A workflow task in FiCR. Tasks organise how evidence is collected, how compliance checking or risk analysis is initiated, and how assessments are produced during fire-related O&amp;M activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Task</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#TestEvidence -->


    <owl:Class rdf:about="https://w3id.org/ficr#TestEvidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#EvidenceItem"/>
        <rdfs:comment xml:lang="en">An evidence item generated by a test or measurement activity to support an assessment finding or record.</rdfs:comment>
        <rdfs:label xml:lang="en">TestEvidence</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#TransformerRoom -->


    <owl:Class rdf:about="https://w3id.org/ficr#TransformerRoom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#PlaceOfSpecialHazard"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#UndeterminedResult -->


    <owl:Class rdf:about="https://w3id.org/ficr#UndeterminedResult">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ComplianceResult"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Unknown -->


    <owl:Class rdf:about="https://w3id.org/ficr#Unknown">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#ConditionState"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#UnprotectedAreaRole -->


    <owl:Class rdf:about="https://w3id.org/ficr#UnprotectedAreaRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#FireProtectionRole"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#UsageType -->


    <owl:Class rdf:about="https://w3id.org/ficr#UsageType">
        <rdfs:comment xml:lang="en">A controlled classification value used to assign use, purpose, or fire-safety role to buildings, spaces, physical objects, zones, or systems. UsageType values are used as controlled vocabulary terms and may be represented through OWL punning where required for value-based class definitions.</rdfs:comment>
        <rdfs:label xml:lang="en">UsageType</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#UtilizationPurpose -->


    <owl:Class rdf:about="https://w3id.org/ficr#UtilizationPurpose">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#UsageType"/>
        <rdfs:comment xml:lang="en">Assigns the planning or occupancy use of a building, such as dwellinghouse, office, hotel, school, shop, or factory. This is distinct from regulatory purpose group classification.</rdfs:comment>
        <rdfs:label xml:lang="en">UtilizationPurpose</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#VerticalTransportSystem -->


    <owl:Class rdf:about="https://w3id.org/ficr#VerticalTransportSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#BuildingSystem"/>
        <rdfs:comment xml:lang="en">A Vertical Transport System (VT) in buildings refers to the equipment and planning used to move people and goods vertically between different floors.</rdfs:comment>
        <rdfs:label xml:lang="en">VerticalTransportSystem</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Wall -->


    <owl:Class rdf:about="https://w3id.org/ficr#Wall">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#StructuralElement"/>
        <rdfs:comment xml:lang="en">A wall in buildings is a vertical structure that defines and separates spaces, provides shelter and security, and can be either load-bearing or non-load-bearing.</rdfs:comment>
        <rdfs:label xml:lang="en">Wall</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#WallFoundation -->


    <owl:Class rdf:about="https://w3id.org/ficr#WallFoundation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#StructuralElement"/>
        <rdfs:comment xml:lang="en">Sub-structure component, typically concrete, brick, or masonry, that transfers loads from the building&apos;s walls down to the ground or a concrete footing</rdfs:comment>
        <rdfs:label xml:lang="en">WallFoundation</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/ficr#Warehouse -->


    <owl:Class rdf:about="https://w3id.org/ficr#Warehouse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#SpaceUsage"/>
    </owl:Class>



    <!-- https://w3id.org/ficr#Window -->


    <owl:Class rdf:about="https://w3id.org/ficr#Window">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ficr#Closing"/>
        <rdfs:comment xml:lang="en">A window is an opening in a building wall for light and air, featuring casements or sashes with glass panes, enhancing natural lighting, ventilation, and aesthetics.</rdfs:comment>
        <rdfs:label xml:lang="en">Window</rdfs:label>
    </owl:Class>



