    <!-- https://w3id.org/ficr#Risk_Evaluation_Tool -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ficr#Risk_Evaluation_Tool">
        <rdf:type rdf:resource="https://w3id.org/ficr#FromUK"/>
        <rdfs:comment xml:lang="en">The Building Risk Evaluation Tool (BRET), is intended to provide an easy to follow insight into how the use, design, and construction material choices can influence the resilience of a building to the challenges presented by fire in terms of property protection, business resilience, and insurability. It may provide benefit to designers during the initial development stages looking to ensure the end result will meet the resilience expectations of the occupier and be insurable, and to insurers triaging new prospects.</rdfs:comment>
    </owl:NamedIndividual>
    


