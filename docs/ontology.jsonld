    "@language" : "en",
    "@value" : "The building is regarded as a multi-storey building if both of the following apply.\r\n• There is more than one gallery.\r\n• The total aggregate area of all the galleries in one space is more than half the floor area of that space."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "MultiStoreyBuilding"
