  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The detection principle of the alarm device, e.g. OpticalSmoke, Ionisation, Heat, MultiSensor, CarbonMonoxide."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#Alarm"
