  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ComplianceResult"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ObservedEvidence",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Evidence collected from the building or its digital sensors during inspection or monitoring, such as RGB images, depth, LiDAR/point clouds, and sensor readings. This class represents the content used for assessment, not the provenance metadata standard itself."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ObservedEvidence"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#EvidenceItem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Office",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Office"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Offices or premises used for any of the following and their control:\r\n• administration\r\n• clerical work (including writing, bookkeeping, sorting papers, filing, typing, duplicating, machine calculating, drawing and the editorial preparation of matter for publication, police and fire and rescue service work)\r\n• handling money (including banking and building society work)\r\n• communications (including postal, telegraph and radio communications)\r\n• radio, television, film, audio or video recording\r\n• performance (premises not open to the public)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Office"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Opening",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Refers to any intentional void in walls, floors, or ceilings for access, light, air, or services, such as doors, windows, ducts, or stairwells."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Opening"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Operational",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Operational"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The system is functioning as designed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Operational"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ImpairmentState"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PassiveFireProtectionRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PassiveFireProtectionRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Describes an element or space that is passively protected by fire-resisting construction, such as a protected circuit with fire-rated cable, a stair enclosed by fire-resisting walls, or a protected corridor."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PassiveFireProtectionRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PerformanceAssertion",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A configuration node representing a performance requirement derived from regulatory sources (e.g. ADB, BDM02). Instances such as req_pg1b_wall carry the required REI value for a given purpose group and element type, and serve as the benchmark in SPARQL compliance queries. Actual performance is expressed directly on physical elements via hasREI and similar data properties."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PerformanceAssertion"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PhysicalObject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Anything that exists in reality and can be located"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PhysicalObject"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PipingSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Includes pipe fittings and accessories. The definition of ‘pipe’ excludes a flue pipe and a pipe used for ventilating purposes, other than a ventilating pipe for an above-ground drainage system."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PipingSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#BuildingSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A room such as any of the following.\r\n• Oil-filled transformer room.\r\n• Switch gear room.\r\n• Boiler room.\r\n• Storage space for fuel or other highly flammable substance(s).\r\n• Room that houses a fixed internal combustion engine."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PlaceOfSpecialHazard"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpaceUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#ServiceUsage"
  }, {
    "@id" : "https://w3id.org/ficr#Warehouse"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedCircuit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An electrical circuit that is protected against fire."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedCircuit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid63"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedCorridor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A corridor that is adequately protected from fire in adjoining areas by fire resisting construction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedCorridor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySpace"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#ProtectedEntranceHall"
  }, {
    "@id" : "https://w3id.org/ficr#ProtectedLobby"
  }, {
    "@id" : "https://w3id.org/ficr#ProtectedShaft"
  }, {
    "@id" : "https://w3id.org/ficr#ProtectedStairwaySpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid67"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedEntranceHall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A circulation area, consisting of a hall or space in a flat, that is enclosed with fire resisting construction other than an external wall of a building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedEntranceHall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySpace"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#ProtectedLobby"
  }, {
    "@id" : "https://w3id.org/ficr#ProtectedShaft"
  }, {
    "@id" : "https://w3id.org/ficr#ProtectedStairwaySpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid73"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedLobby",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A corridor or lobby that is adequately protected from fire in adjoining areas by fire resisting construction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedLobby"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySpace"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#ProtectedShaft"
  }, {
    "@id" : "https://w3id.org/ficr#ProtectedStairwaySpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid79"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedShaft",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A shaft that enables people, air or objects to pass from one compartment to another, and which is enclosed with fire resisting construction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedShaft"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySpace"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#ProtectedStairwaySpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid85"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedStairway",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A stair that leads to a final exit to a place of safety and that is adequately enclosed with fire resisting construction. Included in the definition is any exit passageway between the foot of the stair and the final exit."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedStairway"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid91"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ProtectedStairwaySpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A stairway space that leads to a final exit to a place of safety and that is adequately enclosed with fire resisting construction. Included in the definition is any exit passageway between the foot of the stair and the final exit."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ProtectedStairwaySpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid95"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Classification of a building or compartment by its intended use according to ADB Table 0.1."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Classification"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A dwelling is a unit where one or more people live (whether or not as a sole or main residence) in either of the following situations.\r\n• A single person or people living together as a family.\r\n• A maximum of six people living together as a single household, including where care is provided for residents."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup1"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup1a",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup1a"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A flat is a separate and self-contained premises constructed or adapted for use for residential purposes and forming part of a building from some other part of which it is divided horizontally."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup1a"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup1"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup1b",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup1b"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Dwellinghouse that contains a habitable storey with a floor level a minimum of 4.5m above ground level up to a maximum of 18m."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup1b"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup1"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup1c",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup1c"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Dwellinghouse that does not contain a habitable storey with a floor level a minimum of 4.5m above ground level."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup1c"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup1"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup2",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Residential other than Dwellings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup2"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup2a",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup2a"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Hospital, home, school or other similar establishment, where people sleep on the premises. The building may be either of the following:\r\n• Living accommodation for, or accommodation for the treatment, care or maintenance of, either:\r\n    - disabled people with a range of impairments including physical, sensory and\r\ncognitive impairments, or mental health conditions\r\n    - people under the age of 5 years.\r\n• A place of lawful detention."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup2a"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup2"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup2b",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup2b"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Hotel, boarding house, residential college, hall of residence, hostel or any other residential purpose not described above."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup2b"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup2"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup3",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup3"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Offices or premises used for any of the following and their control:\r\n• administration\r\n• clerical work (including writing, bookkeeping, sorting papers, filing, typing, duplicating, machine calculating, drawing and the editorial preparation of matter for publication, police and fire and rescue service work)\r\n• handling money (including banking and building society work)\r\n• communications (including postal, telegraph and radio communications)\r\n• radio, television, film, audio or video recording\r\n• performance (premises not open to the public)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup3"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup4",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup4"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Shops or premises used for either of the following.\r\n• A retail trade or business (including selling food or drink to the public for immediate consumption, retail by auction, self-selection and over-the-counter wholesale trading, the business of lending books or periodicals for gain, the business of a barber or hairdresser, and the rental of storage space to the public).\r\n• Premises to which the public are invited either:\r\n    – to deliver or collect goods in connection with their hire, repair or other treatment\r\n    – (except in the case of repair of motor vehicles) where the public themselves may carry out such repairs or other treatments."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup4"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup5",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup5"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Place of assembly, entertainment or recreation, including any of the following:\r\n• bingo halls, broadcasting, recording and film studios open to the public, casinos, dance halls\r\n• entertainment, conference, exhibition and leisure centres\r\n• funfairs and amusement arcades\r\n• museums and art galleries, non-residential clubs, theatres, cinemas, concert halls\r\n• educational establishments, dancing schools, gymnasia, swimming pool buildings, riding schools, skating rinks, sports pavilions, sports stadia\r\n• law courts\r\n• churches and other buildings of worship, crematoria\r\n• libraries open to the public, non-residential day centres, clinics, health centres and surgeries\r\n• passenger stations and termini for air, rail, road or sea travel\r\n• public toilets\r\n• zoos and menageries."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup5"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup6",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup6"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Factories and other premises used for any of the following:\r\n• manufacturing, altering, repairing, cleaning, washing, breaking up, adapting or processing any article\r\n• generating power\r\n• slaughtering livestock."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup6"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup7",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Storage and Car Parking"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup7"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup7a",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup7a"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Either of the following:\r\n• place (other than described under 7(b)) for the storage or deposit of goods or materials\r\n• any building not within purpose groups 1 to 6."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup7a"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup7"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#PurposeGroup7b",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup7b"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Car parks designed to admit and accommodate only cars, motorcycles and passenger or light goods vehicles that weigh a maximum of 2500kg gross."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PurposeGroup7b"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup7"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Railing",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A railing refers to a protective barrier or fence, usually made of metal (such as wrought or cast iron, steel, or aluminium), timber, or plastic, designed to provide safety and support."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Railing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RegulatoryRequirement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A configuration node recording the minimum performance value mandated by regulation for a specific element type and purpose group. Instances such as req_pg1b_wall carry the required REI for walls in PG1b, linked to their scope via appliesToElementType and appliesToPurposeGroup."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RegulatoryRequirement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PerformanceAssertion"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RegulatorySource",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A referenced regulatory or standards document used as the normative basis for a check or requirement, such as Approved Document B, BDM02, or related standards. It provides the requirement context and should be versioned where possible."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RegulatorySource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssessmentBasis"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RelevantBoundary",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The boundary or notional boundary that one side of the building faces and/or coincides with, and that is parallel or at an angle of a maximum of 80 degrees to that side of the building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RelevantBoundary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Boundary"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ResidentialCollege",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ResidentialCollege"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for a college providing on-site residential accommodation for students."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ResidentialCollege"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RiskAnalysis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A building risk assessment is a systematic process of identifying, evaluating, and managing potential hazards and their associated risks within a building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RiskAnalysis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Assessment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RiskUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "RiskUnit is an exposure value aggregation unit in insurance assessment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RiskUnit"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Risk_Evaluation_Tool",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FromUK"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Building Risk Evaluation Tool (BRET), is intended to provide an easy to follow insight into how the use, design, and construction material choices can influence the resilience of a building to the challenges presented by fire in terms of property protection, business resilience, and insurability. It may provide benefit to designers during the initial development stages looking to ensure the end result will meet the resilience expectations of the occupier and be insurable, and to insurers triaging new prospects."
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Roof",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A roof is the top covering of a building that provides protection from the elements like rain, sun, snow, and wind."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Roof"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RoofSlab",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A horizontal structural slab forming the topmost floor of a building, directly supporting the roof covering and transferring loads to walls or columns."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RoofSlab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Roof"
  }, {
    "@id" : "https://w3id.org/ficr#Slab"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RoofSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A roof space is the area inside a building between the ceiling of the top floor and the underside of the roof."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RoofSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#RoomSpace"
  }, {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  }, {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Rooflight",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A dome light, lantern light, ridge light."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Rooflight"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Equipment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RooflightOpening",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A skylight, glazed barrel vault or other element to admit daylight through a roof."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RooflightOpening"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Closing"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RoomSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An enclosed space within a building that is not used solely as a circulation space. The term includes not only conventional rooms, but also cupboards that are not fittings and large spaces such as warehouses and auditoria. The term does not include cavities such as ducts, ceiling cavities and roof spaces."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RoomSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  }, {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#RoutineTriggerEvent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A trigger event generated from routine schedules or planned inspection cycles derived from FiCR maintenance and regulatory schedules, such as monthly fire exit checks."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RoutineTriggerEvent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Event"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#School",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#School"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A place of education for children between 2 and 19 years old. The term includes nursery schools, primary schools and secondary schools as defined in the Education Act 1996."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "School"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SelfClosingDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device that closes a door, when open at any angle, against a door frame.\r\nNOTE: If the door is in a cavity barrier, rising butt hinges (which are different from the self-closing device mentioned above) are acceptable."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SelfClosingDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Closing"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Sensor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A sensor in a building is a device that detects environmental changes and sends data to a control system to manage building functions like lighting, HVAC, and safety."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Sensor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Equipment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ServiceShaft",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A service shaft is a vertical passage in a building that houses pipes, cables, and ducts for essential building systems like water, electricity, and ventilation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ServiceShaft"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ServiceUsage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ServiceUsage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A space usage for rooms primarily housing building services equipment and infrastructure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ServiceUsage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpaceUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#Warehouse"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SevereHazard",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#SevereHazard"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire hazard severity classification for spaces with high fire load and combustibility."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SevereHazard"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireHazardSeverity"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ShaftSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A smaller, enclosed vertical space extending through multiple floors used for specific building services, such as elevator hoistways, enclosed stairwells, or ducts for plumbing, electrical, or air-conditioning equipment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ShaftSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid101"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ShelteredHousing",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ShelteredHousing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Includes two or more dwellings in the same building or on adjacent sites, designed and constructed as residential accommodation for vulnerable or elderly people who receive, or will receive, a support service."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ShelteredHousing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Shop",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Shop"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Shops or premises used for either of the following.\r\n• A retail trade or business (including selling food or drink to the public for immediate consumption, retail by auction, self-selection and over the-counter wholesale trading, the business of lending books or periodicals for gain, the business of a barber or hairdresser, and the rental of storage space to the public).\r\n• Premises to which the public are invited either:\r\n– to deliver or collect goods in connection with their hire, repair or other treatment\r\n– (except in the case of repair of motor vehicles) where the public themselves may carry out such repairs or other treatments."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Shop"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SingleStoreyBuilding",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A building that consists of a ground storey only. Basements are not counted as storeys in a building (see Appendix D). A separated part that consists of a ground storey only, with a roof to which access is only provided for repair or maintenance, may be treated as a single storey building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SingleStoreyBuilding"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Building"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Slab",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A slab is the thick, structural concrete element (like reinforced concrete) forming a building's horizontal plane"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Slab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#StructuralElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SolarShadingDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device attached to the external surface of an external wall for reducing heat gain within a building by shading or deflecting sunlight."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SolarShadingDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpecifiedAttachment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SpaceUsage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Describe the uses of the space."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SpaceUsage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UsageType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SpecifiedAttachment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Includes any of the following.\r\n• A balcony attached to an external wall.\r\n• A device for reducing heat gain within a building by deflecting sunlight which is attached to an external wall."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SpecifiedAttachment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SprinklerStatus",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Installation status indicating whether an automatic sprinkler system is installed and to what specification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SprinklerStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#InstallationStatus"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SprinkleredInFull",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#SprinklerStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SprinkleredInFull"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SprinkleredWithExceptions",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#SprinklerStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SprinkleredWithExceptions"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Stair",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "a stairway (or staircase) is a series of steps connecting different levels in a building, serving as a pedestrian route."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Stair"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#StairFlight",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A stair flight (or simply \"flight\") refers to an uninterrupted, continuous sequence of stairs (steps/risers) that connect two levels, floors, or intermediate landings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "StairFlight"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#StairSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A stairway space, also called a stairwell, is the vertical compartment in a building that contains a flight of stairs and the associated landings, hallways, or other areas needed to move between floors."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "StairSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid105"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Storage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Storage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises used for storing goods or materials."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Storage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#StoreyExitRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#StoreyExitRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A final exit, or a doorway that gives direct access into a protected stairway, firefighting lobby or external escape route.\r\nNOTE: If an institutional building is planned to enable progressive horizontal evacuation, a door in a compartment wall is considered a storey exit for the purposes of requirement B1."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "StoreyExitRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#StructuralElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A structural element is a component of a building that is essential for its stability and for transferring loads to the ground, such as foundations, beams, columns, and load-bearing walls."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "StructuralElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#StructuralStabilityAssumption",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#StructuralStabilityAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Assumption that the building structure maintains load-bearing stability for the required period during a fire event."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "StructuralStabilityAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssumptionType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#SwitchGearRoom",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#SwitchGearRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A switchgear room in a building is a dedicated space that houses electrical equipment used to control, protect, and isolate the building's electrical system, such as circuit breakers, switches, and fuses."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SwitchGearRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#TransformerRoom"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Task",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A workflow task in FiCR. Tasks organise how evidence is collected, how compliance is checked against regulations, and how risk is estimated for insurance-related analysis."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Task"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#TransformerRoom",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#TransformerRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A transformer room is a dedicated space within a building that houses transformers and associated electrical equipment to step down high-voltage electricity from the grid to a usable low voltage for the building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TransformerRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#UndeterminedResult",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#UndeterminedResult"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A compliance result indicating that the compliance status could not be determined from available evidence."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "UndeterminedResult"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ComplianceResult"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Unknown",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Unknown"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A condition state indicating that the physical condition of a boundary element cannot be determined from available evidence."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Unknown"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ConditionState"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#UnprotectedAreaRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#UnprotectedAreaRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Unprotected area (in relation to a side or external wall of a building) All of the following are classed as unprotected areas.\r\n• Any part of the external wall that has less than the relevant fire resistance set out in Section 11.\r\n• Any part of the external wall constructed of material more than 1mm thick if that material does not have a class B-s3, d2 rating or better, which is attached or applied, whether for cladding or any other purpose.\r\n• Windows, doors or other openings. This does not include windows that are designed and glazed to give the necessary level of fire resistance and that are not openable.\r\nNOTE: Recessed car parking areas as shown in\r\nDiagram A1 should not be regarded as unprotected\r\nareas."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "UnprotectedAreaRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElementFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#UnsprinkleredOrNonCompliant",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#SprinklerStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "UnsprinkleredOrNonCompliant"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#UsageType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Classification of building, space or component usage."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "UsageType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#UtilizationPurpose",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Building planning of utilization."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "UtilizationPurpose"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UsageType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#VerticalTransportSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A Vertical Transport System (VT) in buildings refers to the equipment and planning used to move people and goods vertically between different floors."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "VerticalTransportSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#BuildingSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Wall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A wall in buildings is a vertical structure that defines and separates spaces, provides shelter and security, and can be either load-bearing or non-load-bearing."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Wall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#StructuralElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#WallFoundation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Sub-structure component, typically concrete, brick, or masonry, that transfers loads from the building's walls down to the ground or a concrete footing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "WallFoundation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#StructuralElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Warehouse",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Warehouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A warehouse is a large building used for storing goods, such as raw materials, finished products, or equipment, until they are needed for manufacturing, distribution, or sale."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Warehouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpaceUsage"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Window",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A window is an opening in a building wall for light and air, featuring casements or sashes with glass panes, enhancing natural lighting, ventilation, and aesthetics."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Window"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Closing"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire safety role specifically assigned to building zones via the hasZoneFireSafetyRole property, enabling zone-level semantic classification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ZoneFireSafetyRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#aboutElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a boundary assumption to the physical element whose fire performance it assesses."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#BoundaryAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "aboutElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#according_to",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/ficr#affectsSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links an impairment state to the building system whose operation is degraded."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#ImpairmentState"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "affectsSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#BuildingSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#appliesToElementType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Specifies the class of physical element this requirement applies to, e.g. ficr:Wall or ficr:Floor."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#RegulatoryRequirement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "appliesToElementType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#appliesToPurposeGroup",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Specifies the building purpose group for which this requirement is applicable."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#RegulatoryRequirement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "appliesToPurposeGroup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#PurposeGroup"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#appliesToRiskUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a boundary assumption or impairment state to the risk unit it influences."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "appliesToRiskUnit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#RiskUnit"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#assessesElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links an assessment to the physical element(s) it evaluates. For compliance assessments, this is the wall, door, or floor being checked. For risk assessments, this covers elements involved in fire spread modelling."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#Assessment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "assessesElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#assessesZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links an assessment to the zone(s) or space(s) it covers. For risk assessments, this is the space whose fire scenario is being evaluated. For compliance assessments, this is the space containing the assessed elements."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#Assessment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "assessesZone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#basedOnRegulation",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a compliance assessment to the regulatory source used to derive the requirement(s)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#ComplianceChecking"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "basedOnRegulation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#RegulatorySource"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#coversSpatialZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a risk unit to the spatial zone whose fire exposure it aggregates."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#RiskUnit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "coversSpatialZone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#declaredExposureValue",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#RiskUnit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "declaredExposureValue"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#documentTitle",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A human-readable title used to display the document in user interfaces."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#DocumentBasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "documentTitle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#documentURI",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A resolvable URI or file path pointing to the document location for human access."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#DocumentBasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "documentURI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#anyURI"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasActualREI",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The actual measured fire resistance period (R=load-bearing, E=integrity, I=insulation) in minutes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasActualREI"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#integer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/ficr#hasREI"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasActualSeparationM",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Measured physical separation distance in metres between two risk units."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasActualSeparationM"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Informational: for future use."
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasArea",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The floor area of a space in square metres."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasArea"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasAssessmentBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links an assessment activity or assessment result to the evidence bundle that supports it."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#Assessment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasAssessmentBasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#AssessmentBasis"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasAssumptionType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a boundary assumption to the category of fire loss assumption relied upon."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#BoundaryAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasAssumptionType"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#AssumptionType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasBuildingHeight",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Height of a building is measured as shown in Appendix D, Diagram D4."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Building"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasBuildingHeight"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasClassification",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "General property relating an entity to its classification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasClassification"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://w3id.org/ficr#isClassificationOf"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasCombinedGrossFloorArea",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Total gross floor area of all storeys in a building, in square metres."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Building"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasCombinedGrossFloorArea"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasComplianceResult",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a compliance checking assessment to the compliance result it produces."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#ComplianceChecking"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasComplianceResult"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#ComplianceResult"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasComponent",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Expressing the compositional relationship of components"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#BuildingSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasComponent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://w3id.org/ficr#isComponentOf"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasConditionState",
