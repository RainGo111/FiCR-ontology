    "@language" : "en",
    "@value" : "Minimum separation distance in metres required to prevent fire spread, computed per NFPA 80A. Stored here as an externally-supplied value; FiCR does not compute this internally."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasRequiredSeparationM"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Informational: for future use."
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasScenario",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a risk assessment to the fire risk scenario(s) it evaluates. Each scenario represents a hypothetical fire origin and its modelled spread, corresponding to the per-room EML calculations in the FiCR risk model."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#RiskAnalysis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasScenario"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ficr#FireRiskScenario"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#hasSeparationRecord",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a risk unit to a separation distance record describing its exposure to an adjacent risk unit."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#RiskUnit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasSeparationRecord"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Informational: for future use."
  } ]
}, {
