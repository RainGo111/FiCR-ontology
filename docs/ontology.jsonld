    "@value" : "Assigns a fire safety role to a physical element, indicating the element's functional contribution to fire protection (e.g. fire separating, fire resisting, passive fire protection)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
