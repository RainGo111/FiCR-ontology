  "@id" : "http://purl.org/dc/terms/license",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/modified",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/title",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/vocab/vann/preferredNamespacePrefix",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/vocab/vann/preferredNamespaceUri",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2001/XMLSchema#date",
  "@type" : [ "http://www.w3.org/2000/01/rdf-schema#Datatype" ]
}, {
  "@id" : "http://www.w3.org/2003/06/sw-vocab-status/ns#term_status",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#altLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#scopeNote",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2006/vcard/ns#fn",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://orcid.org/0000-0001-8020-4609",
  "http://www.w3.org/2006/vcard/ns#fn" : [ {
    "@value" : "Pieter Pauwels"
  } ],
  "https://schema.org/name" : [ {
    "@value" : "Pieter Pauwels"
  } ]
}, {
  "@id" : "https://orcid.org/0000-0002-2033-859X",
  "http://www.w3.org/2006/vcard/ns#fn" : [ {
    "@value" : "Georg Ferdinand Schneider"
  } ],
  "https://schema.org/name" : [ {
    "@value" : "Georg Ferdinand Schneider"
  } ]
}, {
  "@id" : "https://orcid.org/0000-0002-6519-7057",
  "http://www.w3.org/2006/vcard/ns#fn" : [ {
    "@value" : "Mads Holten Rasmussen"
  } ],
  "https://schema.org/name" : [ {
    "@value" : "Mads Holten Rasmussen"
  } ]
}, {
  "@id" : "https://schema.org/domainIncludes",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://schema.org/name",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://schema.org/rangeIncludes",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/bot#Building",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An independent unit of the built environment with a characteristic spatial structure, intended to serve at least one function or user activity [ISO 12006-2:2013]. A bot:Building is a part of the physical world or a virtual world that is inherently both located in this world and having a 3D spatial extent, is contained in a building site, and can contain one or more storeys that are vertically connected.\r\nAny permanent or temporary building but not any other kind of structure or erection. A reference to a building includes a reference to part of a building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Building"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/bot#Site"
  }, {
    "@id" : "https://w3id.org/bot#Space"
  }, {
    "@id" : "https://w3id.org/bot#Storey"
  } ]
}, {
  "@id" : "https://w3id.org/bot#Element",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Physical building elements."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Element"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/bot#Interface"
  }, {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#Interface",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A generic concept to qualify the relationship of two or more things in the world, where at least one is a building element or zone. Examples:\r\n    - Qualification of heat transmission between zones through one or more building elements. This includes one-dimensional (surface) heat losses from one zone to another through a single building element, a two dimensional (line) loss from one zone to another through the connection in which the two elements meet or a three dimensional (point) loss from one zone to another through the connection where three elements (typically two walls and a slab) meet. \r\n    - Connection of an electric device to the electric system of a building. \r\n    - A door between one room and another."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Interface"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#Site",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The land occupied by the building, up to the boundaries with land in other ownership."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Site"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/bot#Space"
  }, {
    "@id" : "https://w3id.org/bot#Storey"
  } ]
}, {
  "@id" : "https://w3id.org/bot#Space",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A part of the physical world or a virtual world whose 3D spatial extent is bounded actually or theoretically, and provides for certain functions within the zone it is contained in."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Space"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/bot#Storey"
  } ]
}, {
  "@id" : "https://w3id.org/bot#Storey",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A part of the physical world or a virtual world that is inherently both located in this world and having a 3D spatial extent. A bot:Storey is contained in one or more buildings, and is intended to contain one or more spaces that are horizontally connected. Storeys of a building are connected by means of vertical connections such as elevators and stairs.\r\nIncludes any of the following.\r\n• Any gallery in an assembly building (purpose group 5).\r\n• Any gallery in any other type of building if its area is more than half that of the space into which it projects.\r\n• A roof, unless it is accessible only for maintenance and repair."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Storey"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#Zone",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A part of the physical world or a virtual world that is inherently both located in this world and has a 3D spatial extent; Sub-classes of bot:Zone include bot:Site, bot:Building, bot:Storey, or bot:Space.  An instance of bot:Zone can contain other bot:Zone instances, making it possible to group or subdivide zones. An instance of bot:Zone can be adjacent to or intersecting other bot:Zone instances. Finally, a bot:Zone can instantiate three relations to bot:Element, which are either contained in (bot:containsElement), adjacent to it (bot:adjacentElement) or intersecting (bot:intersectingElement)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Zone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#adjacentElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "adjacentElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/bot#hasElement"
  } ],
  "http://www.w3.org/2002/07/owl#propertyDisjointWith" : [ {
    "@id" : "https://w3id.org/bot#intersectingElement"
  } ]
}, {
  "@id" : "https://w3id.org/bot#adjacentZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relationship between two zones that share a common interface, but do not intersect."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "adjacentZone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2002/07/owl#propertyDisjointWith" : [ {
    "@id" : "https://w3id.org/bot#intersectsZone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#containsElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "containsElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/bot#hasElement"
  } ],
  "http://www.w3.org/2002/07/owl#propertyChainAxiom" : [ {
    "@list" : [ {
      "@id" : "https://w3id.org/bot#containsZone"
    }, {
      "@id" : "https://w3id.org/bot#containsElement"
    } ]
  } ]
}, {
  "@id" : "https://w3id.org/bot#containsZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relationship to the subzones of a major zone. A space zone could for instance be contained in a storey zone which is further contained in a building zone. bot:containsZone is a transitive property. This implies that in the previous example a bot:containsZone relationship holds between the space zone and the building zone."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "containsZone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#has3DModel",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links any bot:Zone or bot:Element to a IRI that identifies its 3D Model. This 3D Model can then be described using some dedicated RDF vocabulary. Else, the 3D Model IRI could be dereferenceable, and when looking up the IRI one could retrieve a representation of the 3D Model with some existing data format for 3D models."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has3DModel"
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasBuilding",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relation to buildings contained in a zone. The typical domains of bot:hasBuilding are instances of bot:Site."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasBuilding"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Building"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/bot#containsZone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a Zone to an Element that is either contained in, adjacent to or intersecting with the Zone. The intended use of this relationship is not to be stated explicitly, but to be inferred from its sub-properties. It will, for example, allow one to query for all the doors of a building given that they have an adjacency to spaces of the building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Element"
  } ],
  "http://www.w3.org/2002/07/owl#propertyChainAxiom" : [ {
    "@list" : [ {
      "@id" : "https://w3id.org/bot#containsZone"
    }, {
      "@id" : "https://w3id.org/bot#hasElement"
    } ]
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasSimple3DModel",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links any bot:Zone or bot:Element to a 3D Model encoded as a literal."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasSimple3DModel"
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/bot#containsZone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasStorey",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relation to storeys contained in a zone. The typical domains of bot:hasStorey are instances of bot:Building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasStorey"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Storey"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/bot#containsZone"
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasSubElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Element"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasSubElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Element"
  } ]
}, {
  "@id" : "https://w3id.org/bot#hasZeroPoint",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a bot:Site to an instance that encodes the latitude and longitude of the Zero Point of the building site. This could be an instance of a wgs84:Point. The definition of GIS and geometry is not within the scope of BOT and an appropriate ontology needs to be selected here by the user. The use of this property is potentially ambiguous and it might be removed or revised in future editions of the ontology."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Site"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "hasZeroPoint"
  } ]
}, {
  "@id" : "https://w3id.org/bot#interfaceOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relationship between an interface and another thing (building zone, element or owl:Thing)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Interface"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "interfaceOf"
  } ]
}, {
  "@id" : "https://w3id.org/bot#intersectingElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relation between a Zone and a building Element that intersects it."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "intersectingElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/bot#hasElement"
  } ]
}, {
  "@id" : "https://w3id.org/bot#intersectsZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relationship between two zones whose 3D extent intersect. For example, a stairwell intersects different storeys."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "intersectsZone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/ficr",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Dayou Chen"
  }, {
    "@value" : "Long Chen"
  }, {
    "@value" : "Yu Zhang"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "FiCR, Fire Compliance and Risk Analysis, is a domain specific semantic model designed to represent fire safety and fire risk relevant physical objects, building elements, equipment, functional roles, and their relationships in existing buildings. It supports a structured and interoperable representation of both passive and active fire protection measures, as well as risk related attributes and performance outcomes, enabling compliance assessment, fire risk analysis, and inspection activities throughout the building operation and maintenance phase. FiCR further provides a semantic foundation for rule based reasoning and fire oriented digital twins that integrate regulatory compliance and risk informed decision making."
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2025-06-26"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2025-06-26"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "FiCR: Fire Compliance and Risk Analysis Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "ficr"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://w3id.org/ficr#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "FiCR, Fire Compliance and Risk Analysis Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/ficr/1.0.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0.0"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ADB",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FromUK"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Approved Document B Volume 1&2\r\nBuilding regulation in England covering fire safety matters within and around buildings."
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AccessRoomRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#AccessRoomRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Access role refers to the room that the only escape route from an inner room passes through."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AccessRoomRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Accommodation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Accommodation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises providing temporary or permanent residential living."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accommodation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ActiveFireProtectionRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ActiveFireProtectionRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Describes a system or element that actively detects or suppresses fire, such as sprinkler systems, fire alarm circuits, and emergency lighting systems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ActiveFireProtectionRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Alarm",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An alarm in a building is a system designed to alert occupants to a potential danger, such as fire or intrusion, and consists of detectors, warning devices, and control equipment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Alarm"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Equipment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AlarmInstallationStatus",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Installation and specification status of fire alarm systems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AlarmInstallationStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#InstallationStatus"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AlternativeEscapeRouteRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#AlternativeEscapeRouteRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Escape routes that are sufficiently separated by direction and space or by fire resisting construction to ensure that one is still available if the other is affected by fire.\r\nA second stair, balcony or flat roof which enables a person to reach a place free from danger from fire is considered an alternative escape route for the purposes of a dwellinghouse."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AlternativeEscapeRouteRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AlternativeExitRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#AlternativeExitRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "One of two or more exits, each of which is separate from the other."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AlternativeExitRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AnomalyTriggerEvent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A trigger event generated when abnormal conditions are detected by monitoring or analytics, causing tasks to be created for verification, inspection, or risk follow-up."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AnomalyTriggerEvent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Event"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ApplianceVentilationDuct",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A duct to deliver combustion air to a gas appliance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ApplianceVentilationDuct"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#HVACSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AssemblyPlace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#AssemblyPlace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises used for public assembly, entertainment, or recreation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AssemblyPlace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Assessment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An assessment outcome produced by executing tasks, supported by evidence, and traceable to triggering events."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Assessment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AssessmentBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A bundle of evidence items used to justify a fire compliance evaluation or risk assessment. It groups observed site evidence, regulatory sources, and supporting external documents for traceability and explanation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AssessmentBasis"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AssumptionType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The different types of assumptions relied upon include: floor partitions prevent vertical spread, internal cavities do not spread fire, external walls do not cause external spread, and building structural stability."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AssumptionType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AtriumSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A continuous space that passes through one or more structural floors within a building, not necessarily vertically.\r\nEnclosed lift wells, enclosed escalator wells, building services ducts and stairs are not classified as atria."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AtriumSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#BalconySpace"
  }, {
    "@id" : "https://w3id.org/ficr#CavitySpace"
  }, {
    "@id" : "https://w3id.org/ficr#DuctSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoofSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoomSpace"
  }, {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  }, {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Auditorium",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Auditorium"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An auditorium is a large room or building designed for public gatherings, such as performances, lectures, or meetings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Auditorium"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpaceUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#Bathroom"
  }, {
    "@id" : "https://w3id.org/ficr#CirculationUsage"
  }, {
    "@id" : "https://w3id.org/ficr#Gallery"
  }, {
    "@id" : "https://w3id.org/ficr#HabitableRoom"
  }, {
    "@id" : "https://w3id.org/ficr#Kitchen"
  }, {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  }, {
    "@id" : "https://w3id.org/ficr#ServiceUsage"
  }, {
    "@id" : "https://w3id.org/ficr#Warehouse"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#AutomaticReleaseMechanism",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device that normally holds a door open, but closes it automatically if any one of the following occurs.\r\n• Smoke is detected by an automatic device of a suitable nature and quality in a suitable location.\r\n• A hand-operated switch, fitted in a suitable position, is operated.\r\n• The electricity supply to the device, apparatus or switch fails.\r\n• The fire alarm system, if any, is operated."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AutomaticReleaseMechanism"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BDM02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FromUK"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Fire Protection of Buildings\r\nRISCAuthority BDM02 - Fire Protection of Buildings - 2022 v2 A4"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BS_EN_12845",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FromUK"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Fixed firefighting systems. Automatic sprinkler systems. Design, installation and maintenance."
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BalconySpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A balcony is a platform projecting from the wall of a building, enclosed by a balustrade or railing, and accessed from an upper-level room."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BalconySpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#CavitySpace"
  }, {
    "@id" : "https://w3id.org/ficr#DuctSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoofSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoomSpace"
  }, {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  }, {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BasementStorey",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A storey with a floor that, at some point, is more than 1200mm below the highest level of ground beside the outside walls. (However, see Appendix B, paragraph B26c, for situations where the storey is considered to be a basement only because of a sloping site.)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BasementStorey"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Storey"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#GroundAndAboveStorey"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid5"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Bathroom",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Bathroom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "a room for washing and personal hygiene, typically containing a toilet, sink, and either a bathtub or shower."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Bathroom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpaceUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#CirculationUsage"
  }, {
    "@id" : "https://w3id.org/ficr#Gallery"
  }, {
    "@id" : "https://w3id.org/ficr#HabitableRoom"
  }, {
    "@id" : "https://w3id.org/ficr#Kitchen"
  }, {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  }, {
    "@id" : "https://w3id.org/ficr#ServiceUsage"
  }, {
    "@id" : "https://w3id.org/ficr#Warehouse"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Beam",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A beam is a horizontal structural element that carries loads perpendicular to its length, transferring weight from a roof, floor, or ceiling to vertical supports like columns or walls."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Beam"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#StructuralElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BoardingHouse",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#BoardingHouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises providing lodging and meals for paying guests."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BoardingHouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BoilerRoom",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#BoilerRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A boiler room is a dedicated space in a building that houses essential mechanical equipment for services like heating, hot water, and electricity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BoilerRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#EngineRoom"
  }, {
    "@id" : "https://w3id.org/ficr#FuelStorage"
  }, {
    "@id" : "https://w3id.org/ficr#SwitchGearRoom"
  }, {
    "@id" : "https://w3id.org/ficr#TransformerRoom"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Boundary",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The boundary of the land that belongs to a building, or, where the land abuts a road, railway, canal or river, the centre line of that road, railway, canal or river."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Boundary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BoundaryAssumption",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicates fire loss boundary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BoundaryAssumption"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BuildingContent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Furniture, equipment, inventory - not part of building structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BuildingContent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#BuildingSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A building system refers to the interconnected, functional components of a building, including its mechanical, and electrical infrastructure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BuildingSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CarParking",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CarParking"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises designed for vehicle parking and storage."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CarParking"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CavityBarrier",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A construction within a cavity, other than a smoke curtain, to perform either of the\r\nfollowing functions.\r\n• Close a cavity to stop smoke or flame entering.\r\n• Restrict the movement of smoke or flame within a cavity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CavityBarrier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CavityBarrierAssumption",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CavityBarrierAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Assumption that internal cavities are adequately sealed by cavity barriers and do not provide a path for fire spread."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CavityBarrierAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssumptionType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CavitySpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A space enclosed by elements of a building (including a suspended ceiling) or contained within an element, but that is not a room, cupboard, circulation space, protected shaft, or space within a flue, chute, duct, pipe or conduit."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CavitySpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#DuctSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoofSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoomSpace"
  }, {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  }, {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Ceiling",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Part of a building that encloses a room, protected shaft or circulation space and is exposed overhead.\r\nThe soffit of a rooflight, but not the frame, is included as part of the surface of the ceiling. An upstand below a rooflight is considered as a wall."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Ceiling"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Circuit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A continuous pathway that allows electricity to flow from the main supply (consumer unit) to various outlets, lights, or appliances, and back again."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Circuit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElectricalSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CirculationSpaceRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CirculationSpaceRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Circulation space refers to a space (including a protected stairway) mainly used as a means of access between a room and an exit from the building or compartment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CirculationSpaceRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CirculationUsage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CirculationUsage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A space usage for areas primarily serving pedestrian movement, such as corridors, halls, and lobbies."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CirculationUsage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#SpaceUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#Gallery"
  }, {
    "@id" : "https://w3id.org/ficr#HabitableRoom"
  }, {
    "@id" : "https://w3id.org/ficr#Kitchen"
  }, {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  }, {
    "@id" : "https://w3id.org/ficr#ServiceUsage"
  }, {
    "@id" : "https://w3id.org/ficr#Warehouse"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Cladding",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Cladding is an external layer applied to a building's structure to provide weather protection, thermal insulation, and improved aesthetics."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cladding"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ExternalWall"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Classification",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Classify buildings or compartments according to their intended use, construction type, or structural risk to ensure safety, regulatory compliance, and facilitate communication between professionals such as planners, insurers, and contractors."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Classification"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Closing",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fabric element category for components that close openings in the building envelope or internal partitions, including doors, windows, and dampers."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Closing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Column",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A column is a vertical structural element in a building that supports loads from above and transfers them down to the foundation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Column"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#StructuralElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CommercialPlace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CommercialPlace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises used for commercial trading activities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CommercialPlace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CompartmentFloor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire resisting floor to separate one fire compartment from another."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CompartmentFloor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid9"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CompartmentWall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire resisting wall to separate one fire compartment from another.\r\nincluding a wall that is common to two or more buildings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CompartmentWall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid13"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CompartmentationAssumption",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CompartmentationAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Assumption that floor and wall partitions maintain fire compartmentation and prevent vertical or horizontal fire spread."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CompartmentationAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssumptionType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ComplianceChecking",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An assessment that determines whether requirements derived from a regulatory source are satisfied, producing a compliance result and justification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ComplianceChecking"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Assessment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ComplianceCheckingTask",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A task that evaluates one or more requirements against available evidence and produces a compliance result."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ComplianceCheckingTask"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Task"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ComplianceRequestTriggerEvent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A trigger event created when a compliance request is received from an external authority, or when a prior task identifies missing evidence or unmet preconditions requiring follow-up inspection or assessment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ComplianceRequestTriggerEvent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Event"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ComplianceResult",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The outcome of a compliance assessment, representing a discrete compliance status such as compliant, non-compliant, or undetermined. It is produced by a ComplianceAssessment via hasComplianceResult and can be consumed by a FireRiskAssessmentTask via usesComplianceResult to inform risk calculations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ComplianceResult"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#CompliantResult",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#CompliantResult"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A compliance result indicating that the assessed element or system meets the applicable regulatory requirement."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CompliantResult"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ComplianceResult"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Compromised",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Compromised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A condition state indicating that the physical performance of a boundary element is degraded or unreliable."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Compromised"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ConditionState"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ConditionState",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Physical performance status assessment of boundary condition state."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ConditionState"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Controller",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In buildings, a \"controller\" is the \"brain\" of an automated system, receiving data from sensors and sending commands to devices like HVAC, lighting, and alarms to ensure comfort and efficiency."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Controller"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Equipment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Corridor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Corridor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A corridor is a long, narrow passageway in a building that connects different rooms or areas.\r\nA design of a building containing flats, in which each flat is approached via a common horizontal internal access or circulation space, which may include a common entrance hall."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Corridor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#CirculationUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#EntranceHall"
  }, {
    "@id" : "https://w3id.org/ficr#Foyer"
  }, {
    "@id" : "https://w3id.org/ficr#Hall"
  }, {
    "@id" : "https://w3id.org/ficr#Lobby"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Curtain",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Part of a solar shading device which is set in motion by the operating system and fulfils the purpose of a blind, awning or shutter."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Curtain"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#DeadEndRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#DeadEndRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An area from which escape is possible in one direction only."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "DeadEndRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#DetentionHouse",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#DetentionHouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises used for lawful detention of persons."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "DetentionHouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#DocumentBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An external file or record that supports assessment or documentation, such as product data sheets, installation manuals, certificates, drawings, or inspection reports. It is linked for human access and traceability and does not directly participate in logical inference unless explicitly modelled."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "DocumentBasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssessmentBasis"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Doorset",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A doorset is a complete, integrated door system consisting of the door leaf, frame, and all necessary hardware like hinges, seals, and closers, sold as a single unit from one source."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Doorset"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Closing"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#DuctSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A duct space is a designated area or channel within a building that houses the systems for conveying air, cables, and other utilities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "DuctSpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Space"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#RoofSpace"
  }, {
    "@id" : "https://w3id.org/ficr#RoomSpace"
  }, {
    "@id" : "https://w3id.org/ficr#ShaftSpace"
  }, {
    "@id" : "https://w3id.org/ficr#StairSpace"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Dwellinghouse",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Dwellinghouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Does not include a flat or a building containing a flat."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Dwellinghouse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Effective",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Effective"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A condition state indicating that the physical performance of a boundary element is intact and functioning as designed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Effective"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ConditionState"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ElectricalSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An electrical system in a building is a network of wiring, equipment, and protective devices that safely distributes power from its entry point to all the loads, such as lights, outlets, and appliances, within the structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ElectricalSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#BuildingSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ElementFireSafetyRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ElementFireSafetyRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire safety role specifically assigned to physical building elements via the hasElementUsage property, forming the basis of the semantic bridging pattern."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ElementFireSafetyRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EmergencyLighting",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Lighting for use when the power supply to the normal lighting fails."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EmergencyLighting"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElectricalSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EngineRoom",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#EngineRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In buildings, an \"engine room\" typically refers to the central location for the mechanical and electrical systems that keep the building running, such as HVAC, boilers, generators, and pumps."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EngineRoom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#PlaceOfSpecialHazard"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#FuelStorage"
  }, {
    "@id" : "https://w3id.org/ficr#SwitchGearRoom"
  }, {
    "@id" : "https://w3id.org/ficr#TransformerRoom"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EntertainmentPlace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#EntertainmentPlace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A utilization purpose for premises used for entertainment or recreational activities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EntertainmentPlace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EntranceHall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#EntranceHall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A hall or space inside a dwelling that connects\r\nthe entrance door to the rooms."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EntranceHall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#CirculationUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#Foyer"
  }, {
    "@id" : "https://w3id.org/ficr#Hall"
  }, {
    "@id" : "https://w3id.org/ficr#Lobby"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Equipment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Independently identifiable. Maintainable/inspectable. Usually has a model/serial number. Replaceable physical device or apparatus."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Equipment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Element"
  }, {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EquipmentInspectionTask",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Inspection task consumes observations produced by upstream tools."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EquipmentInspectionTask"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Task"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EscapeLighting",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The part of the emergency lighting that is provided to ensure that the escape route is illuminated at all material times."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EscapeLighting"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#EmergencyLighting"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EvacuationLift",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A lift that may be used to evacuate people in a fire."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EvacuationLift"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#LiftSystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid17"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EvacuationRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#EvacuationRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The route along which people can escape from any point in a building to a final exit."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EvacuationRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElementFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Event",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An occurrence that triggers the creation of one or more tasks in the FiCR workflow, such as a routine schedule, an anomaly alert, or a compliance request."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Event"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#EvidenceItem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A single piece of evidence that supports an assessment. It may be an observation, a regulatory reference, or an external document. Evidence items are linkable, traceable, and can be attached to specific assets, spaces, or checks."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EvidenceItem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssessmentBasis"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ExitPassagewayRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ExitPassagewayRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A protected passageway that connects a protected stairway to a final exit."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ExitPassagewayRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ZoneFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ExternalSpreadAssumption",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#ExternalSpreadAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Assumption that the external wall construction does not contribute to external fire spread between compartments or buildings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ExternalSpreadAssumption"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#AssumptionType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ExternalWall",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The external wall of a building includes all of the following.\r\n• Anything located within any space forming part of the wall.\r\n• Any decoration or other finish applied to any external (but not internal) surface forming part of the wall.\r\n• Any windows and doors in the wall.\r\n• Any part of a roof pitched at an angle of more than 70 degrees to the horizontal if that part of the roof adjoins a space within the building to which persons have access, but not access only for the purpose of carrying out repairs or maintenance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ExternalWall"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Wall"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid21"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ExternalWallDoor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An external wall door is a door that is part of a building's exterior wall, providing an entrance and exit to the building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ExternalWallDoor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Doorset"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid25"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#ExternalWallWindow",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An external wall window is a window that is part of a building's exterior wall, which acts as the outer boundary separating the interior from the outside environment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ExternalWallWindow"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Window"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid29"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FabricElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Building structural components. Aligning the BuildingElement with the BOT."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FabricElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Element"
  }, {
    "@id" : "https://w3id.org/ficr#PhysicalObject"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Factory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Factory"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Assumption that the external wall construction does not contribute to external fire spread between compartments or buildings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Factory"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FinalExitRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FinalExitRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The end of an escape route from a building that gives direct access to a street, passageway, walkway or open space, and is sited to ensure that people rapidly disperse away from the building so that they are no longer in danger from fire and/or smoke.\r\nWindows are not acceptable as final exits."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FinalExitRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Finishes",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Finishes are the final surface treatments and decorative elements applied to a building's interior and exterior."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Finishes"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#BuildingContent"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireAlarmSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Combination of components for giving an audible and/or other perceptible warning of fire."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireAlarmSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireAndSmokeDamper",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire damper which, in addition to the performance of the fire damper, resists the spread of smoke."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireAndSmokeDamper"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireDamper"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireCompartment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire safety space bounded by compartment walls and compartment floors, designed to prevent the spread of fire and smoke beyond the compartment of origin."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireCompartment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySpace"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid33"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireDamper",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A mechanical or intumescent device within a duct or ventilation opening that operates automatically and is designed to resist the spread of fire."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireDamper"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid39"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireDamperInstallationStatus",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Installation and specification status of fire dampers within ductwork."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireDamperInstallationStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#InstallationStatus"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireDoorset",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A door or shutter which, together with its frame and furniture as installed in a building, is intended (when closed) to resist the spread of fire and/or gaseous products of combustion and meets specified performance criteria to those ends."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireDoorset"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid43"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireExtinguisher",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A portable or fixed manually-operated device containing an extinguishing agent that can be expelled for the purpose of suppressing or extinguishing a fire. Fire extinguishers are classified by their agent type (water, foam, CO2, dry powder, wet chemical) and by the fire classes they are rated to address."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireExtinguisher"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Equipment"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireFightingLift",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A lift with additional protection and with controls that enable it to be used by the fire and rescue service when fighting a fire."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireFightingLift"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#LiftSystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid51"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireHazardSeverity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Fire hazard severity classification: light, moderate, or severe."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireHazardSeverity"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireResistingRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FireResistingRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "same as Fire Resistance\r\nThe ability of a component or a building to satisfy, for a stated period of time, some or all of the appropriate criteria given in the relevant standard."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireResistingRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElementFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireRiskAssessmentTask",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A task that estimates insurance-relevant risk metrics such as EML and PML by combining asset exposure, compliance outcomes, and supporting evidence."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireRiskAssessmentTask"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Task"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireRiskScenario",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A hypothetical fire scenario anchored to a specific origin space (via hasOriginSpace). It models fire ignition, horizontal and vertical spread pathways, and resulting loss exposure. Each space in the building can serve as the origin of a distinct scenario, and a RiskAssessment evaluates one or more scenarios via hasScenario."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireRiskScenario"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireSafetyRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Abstract analytical concepts for spatial relationships and paths, not physical entities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireSafetyRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UsageType"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireSafetySpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "\"Fire safety space\" in a building refers to the areas designed to prevent the spread of fire and smoke and guide occupants to safety."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireSafetySpace"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/bot#Zone"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireSafetySystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire safety system in buildings is a collection of equipment and practices designed to detect, alert occupants of, and control or extinguish fires, thereby protecting lives and property."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireSafetySystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#BuildingSystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireSeparatingRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FireSeparatingRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A compartment wall, compartment floor, cavity barrier and construction that encloses a protected escape route and/or a place of special fire hazard."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireSeparatingRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElementFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireSprinklerSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fire protection system in a building is a coordinated set of equipment and procedures designed to detect, control, and extinguish fires to safeguard lives and property."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireSprinklerSystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid55"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FireStop",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A seal provided to close an imperfection of fit or design tolerance between elements or components, to restrict the spread of fire and smoke."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FireStop"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FireSafetySystem"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FirefightingRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#FirefightingRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Firefighting in buildings is the strategic and tactical process used by the fire and rescue service to control and extinguish fires, protect lives and property, and manage associated hazards within a built structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FirefightingRole"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#ElementFireSafetyRole"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Flat",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Flat"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A flat is a separate and self-contained premises constructed or adapted for use for residential purposes and forming part of a building from some other part of which it is divided horizontally."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Flat"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#UtilizationPurpose"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Floor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A floor is the horizontal surface in a building that forms the base of a room, providing structural support for occupants, furniture, and the building's own weight."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Floor"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#FabricElement"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FloorSlab",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A horizontal structural slab forming an intermediate or ground-level floor, transferring occupancy and dead loads to the supporting structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "FloorSlab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#Floor"
  }, {
    "@id" : "https://w3id.org/ficr#Slab"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#Foyer",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/ficr#Foyer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The large area where people meet or wait just inside the main doors of a building."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Foyer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/ficr#CirculationUsage"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/ficr#Hall"
  }, {
    "@id" : "https://w3id.org/ficr#Lobby"
  } ]
}, {
  "@id" : "https://w3id.org/ficr#FromUK",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
