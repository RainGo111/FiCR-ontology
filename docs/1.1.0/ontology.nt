# 
# https://w3id.org/ficr#documentTitle
<https://w3id.org/ficr#documentTitle> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<https://w3id.org/ficr#documentTitle> <http://www.w3.org/2000/01/rdf-schema#domain> <https://w3id.org/ficr#AssessmentBasis> .
<https://w3id.org/ficr#documentTitle> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#string> .
<https://w3id.org/ficr#documentTitle> <http://www.w3.org/2000/01/rdf-schema#comment> "A human-readable title used to display the document in user interfaces."@en .
<https://w3id.org/ficr#documentTitle> <http://www.w3.org/2000/01/rdf-schema#label> "documentTitle"@en .
# 
# https://w3id.org/ficr#documentURI
<https://w3id.org/ficr#documentURI> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<https://w3id.org/ficr#documentURI> <http://www.w3.org/2000/01/rdf-schema#domain> <https://w3id.org/ficr#AssessmentBasis> .
<https://w3id.org/ficr#documentURI> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#anyURI> .
<https://w3id.org/ficr#documentURI> <http://www.w3.org/2000/01/rdf-schema#comment> "A resolvable URI or file path pointing to the document location for human access."@en .
<https://w3id.org/ficr#documentURI> <http://www.w3.org/2000/01/rdf-schema#label> "documentURI"@en .
# 
# https://w3id.org/ficr#hasActualREI
<https://w3id.org/ficr#hasActualREI> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
<https://w3id.org/ficr#hasActualREI> <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://www.w3.org/2002/07/owl#topDataProperty> .
<https://w3id.org/ficr#hasActualREI> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2001/XMLSchema#integer> .
<https://w3id.org/ficr#hasActualREI> <http://www.w3.org/2000/01/rdf-schema#comment> "The actual measured fire resistance period (R=load-bearing, E=integrity, I=insulation) in minutes."@en .
<https://w3id.org/ficr#hasActualREI> <http://www.w3.org/2000/01/rdf-schema#label> "hasActualREI"@en .
# 
# https://w3id.org/ficr#hasActualSeparationM
<https://w3id.org/ficr#hasActualSeparationM> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#DatatypeProperty> .
